{% extends 'admin/base.html.twig' %}

{% block title %}Ícones — Web Awesome{% endblock %}

{% block breadcrumbs %}
    {% set breadcrumbs = [
        { label: 'Dashboard', route: 'admin_dash' },
        { label: 'Ícones', route: null }
    ] %}
    {{ include('admin/_partials/breadcrumbs.html.twig', { breadcrumbs: breadcrumbs }) }}
{% endblock %}

{% block stylesheets %}
<style>
    .icon-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(96px, 1fr));
        gap: 6px;
    }
    .icon-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 12px 6px;
        border: 1.5px solid var(--bm-border);
        border-radius: var(--radius-base);
        cursor: pointer;
        transition: all .15s;
        background: var(--bm-card-bg);
        min-height: 76px;
    }
    .icon-card:hover {
        border-color: var(--bm-accent);
        background: rgba(79,142,247,.07);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(79,142,247,.15);
    }
    .icon-card i { font-size: 22px; color: var(--bm-text); width: 22px; text-align: center; }
    .icon-card:hover i { color: var(--bm-accent); }
    .icon-name {
        font-size: 10px;
        color: var(--bm-text-muted);
        word-break: break-word;
        text-align: center;
        line-height: 1.3;
        max-width: 100%;
    }
    .icon-card:hover .icon-name { color: var(--bm-accent); }
    .icon-card.hidden { display: none !important; }

    .cat-title {
        font-size: 11.5px;
        font-weight: 700;
        letter-spacing: .7px;
        text-transform: uppercase;
        color: var(--bm-text-muted);
        margin: 0 0 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .cat-count {
        background: var(--bm-border);
        color: var(--bm-text-muted);
        font-size: 10px;
        padding: 1px 6px;
        border-radius: 10px;
    }
    .cat-section { margin-bottom: 28px; }

    .copy-toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(16px);
        background: #1e293b;
        color: #e2e8f0;
        padding: 9px 18px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        opacity: 0;
        pointer-events: none;
        transition: all .25s;
        z-index: 9999;
        box-shadow: 0 4px 16px rgba(0,0,0,.3);
    }
    .copy-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    .filter-bar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .chip {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 14px; border-radius: 20px;
        border: 1.5px solid var(--bm-border); background: transparent;
        color: var(--bm-text-muted); font-size: 12.5px; font-weight: 500;
        cursor: pointer; transition: all .15s;
    }
    .chip:hover, .chip.active {
        border-color: var(--bm-accent);
        background: rgba(79,142,247,.1);
        color: var(--bm-accent);
    }
    .search-wrap { position: relative; }
    .search-wrap i {
        position: absolute;
        top: 50%; left: 10px;
        transform: translateY(-50%);
        color: var(--bm-text-muted);
        font-size: 13px;
        pointer-events: none;
    }
    .search-input {
        padding: 7px 12px 7px 32px;
        border: 1.5px solid var(--bm-input-border);
        border-radius: 20px;
        background: var(--bm-input-bg);
        color: var(--bm-text);
        font-size: 13px; outline: none;
        min-width: 220px;
        transition: border-color .15s, box-shadow .15s;
    }
    .search-input:focus {
        border-color: var(--bm-accent);
        box-shadow: 0 0 0 3px rgba(79,142,247,.2);
    }

    /* Usage demos */
    .code-box {
        background: #0d1117;
        border: 1px solid #21262d;
        border-radius: var(--radius-base);
        padding: 14px 16px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: #8b949e;
        overflow-x: auto;
        margin-top: 10px;
    }
    .code-box .kw  { color: #ff7b72; }
    .code-box .at  { color: #79c0ff; }
    .code-box .val { color: #a5d6ff; }
    .code-box .str { color: #a8d5a2; }
    .code-box .cm  { color: #6e7681; font-style: italic; }
</style>
{% endblock %}

{% block body %}

<div class="copy-toast" id="copy-toast" role="status" aria-live="polite">✓ Copiado!</div>

{# ── Header ── #}
<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-palette" style="margin-right:8px;color:var(--bm-accent);font-size:20px" aria-hidden="true"></i>
            Ícones — Web Awesome (FA6 Free)
        </h1>
        <p class="page-subtitle">
            Ícones disponíveis no plano gratuito. Clique para copiar o código HTML.
            Pesquise, filtre por variante e categoria.
        </p>
    </div>
    <a href="https://fontawesome.com/icons?f=classic&s=solid&q=&o=r" target="_blank" rel="noopener" class="btn-secondary">
        <i class="fa-solid fa-arrow-up-right-from-square" style="font-size:13px" aria-hidden="true"></i>
        FA6 Free Docs
    </a>
</div>

{# ── Como usar ── #}
<div class="admin-card" style="margin-bottom:20px">
    <div class="admin-card-title">
        <i class="fa-solid fa-code" style="color:var(--bm-accent);font-size:15px" aria-hidden="true"></i>
        Como usar
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px">

        <div>
            <p style="font-size:13px;color:var(--bm-text-muted);margin:0 0 6px">Sintaxe básica:</p>
            <div class="code-box"><span class="kw">&lt;wa-icon</span>
  <span class="at">family</span>=<span class="str">"classic"</span>
  <span class="at">variant</span>=<span class="str">"solid"</span>   <span class="cm">{ solid | regular | light | thin | duotone }</span>
  <span class="at">name</span>=<span class="str">"house"</span>
  <span class="at">aria-hidden</span>=<span class="str">"true"</span>
<span class="kw">&gt;&lt;/wa-icon&gt;</span></div>
        </div>

        <div>
            <p style="font-size:13px;color:var(--bm-text-muted);margin:0 0 6px">Tamanhos (font-size):</p>
            <div style="display:flex;align-items:flex-end;gap:16px;flex-wrap:wrap">
                {% for size in [12, 16, 20, 28, 40] %}
                <div style="display:flex;flex-direction:column;align-items:center;gap:5px">
                    <i class="fa-solid fa-star" style="font-size:{{ size }}px;color:var(--bm-accent);display:block" aria-hidden="true"></i>
                    <span style="font-size:10.5px;color:var(--bm-text-muted)">{{ size }}px</span>
                </div>
                {% endfor %}
            </div>
        </div>

        <div>
            <p style="font-size:13px;color:var(--bm-text-muted);margin:0 0 6px">Variantes (mesmo ícone):</p>
            <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
                {% for variant in ['thin','light','regular','solid','duotone'] %}
                <div style="display:flex;flex-direction:column;align-items:center;gap:5px">
                    <i class="fa-solid fa-bell" style="font-size:22px;color:var(--bm-text);display:block" aria-hidden="true"></i>
                    <span style="font-size:10px;color:var(--bm-text-muted)">{{ variant }}</span>
                </div>
                {% endfor %}
            </div>
        </div>

        <div>
            <p style="font-size:13px;color:var(--bm-text-muted);margin:0 0 6px">Ícone em input (padrão correto):</p>
            <div style="position:relative;max-width:220px">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true" style="position:absolute;top:50%;left:11px;transform:translateY(-50%);color:var(--bm-text-muted);pointer-events:none;z-index:2;font-size:14px;display:block"></i>
                <input type="text" class="wab-input" style="padding-left:36px" placeholder="Pesquisar...">
            </div>
            <div class="code-box"><span class="cm">&lt;!-- wa-icon diretamente no div pai --&gt;</span>
<span class="kw">&lt;div</span> <span class="at">style</span>=<span class="str">"position:relative"</span><span class="kw">&gt;</span>
  <span class="kw">&lt;wa-icon</span> <span class="at">name</span>=<span class="str">"magnifying-glass"</span>
           <span class="at">style</span>=<span class="str">"position:absolute;top:50%;left:11px;
                  transform:translateY(-50%);font-size:14px"</span><span class="kw">&gt;&lt;/wa-icon&gt;</span>
  <span class="kw">&lt;input</span> <span class="at">style</span>=<span class="str">"padding-left:36px"</span><span class="kw">&gt;</span>
<span class="kw">&lt;/div&gt;</span></div>
        </div>

    </div>
</div>

{# ── Biblioteca ── #}
<div class="admin-card">
    <div class="admin-card-title">
        <i class="fa-solid fa-grid-2" style="color:var(--bm-accent);font-size:15px" aria-hidden="true"></i>
        Biblioteca
        <span style="font-size:12px;font-weight:400;color:var(--bm-text-muted);margin-left:auto">Clique → copia código</span>
    </div>

    <div class="filter-bar">
        <div class="search-wrap">
            <i class="fa-solid fa-magnifying-glass" style="position:absolute;top:50%;left:10px;transform:translateY(-50%);color:var(--bm-text-muted);font-size:13px;pointer-events:none;display:block" aria-hidden="true"></i>
            <input type="text" id="icon-search" class="search-input"
                   placeholder="Pesquisar ícone..." oninput="filterIcons()"
                   aria-label="Pesquisar ícones">
        </div>
        <button class="chip active" onclick="setVariant('solid',this)">
            <i class="fa-solid fa-star" style="font-size:13px;display:block" aria-hidden="true"></i> solid
        </button>
        <button class="chip" onclick="setVariant('regular',this)">
            <i class="fa-regular fa-star" style="font-size:13px;display:block" aria-hidden="true"></i> regular
        </button>
        <span id="icon-count" style="font-size:12.5px;color:var(--bm-text-muted);margin-left:4px"></span>
    </div>

    {# Ícones renderizados por JS abaixo #}
    <div id="icon-library"></div>
</div>

{% endblock %}


