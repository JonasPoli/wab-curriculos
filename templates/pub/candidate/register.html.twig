{% extends 'pub/base.html.twig' %}
{% set tenant = tenant|default(current_tenant()) %}
{% block title %}Cadastrar Currículo{% endblock %}

{% block body %}
<div class="pub-page-auth">
    <div class="auth-card">

        <div class="auth-panel-left">
            <div class="auth-panel-left-content">
                {% if tenant.darkLogo %}
                    <img src="{{ tenant_logo_url(tenant.darkLogo, 'dark-logo') }}" alt="{{ tenant.name }}" class="auth-panel-logo" style="filter:none" width="150" height="40">
                {% elseif tenant.logo %}
                    <img src="{{ tenant_logo_url(tenant.logo, 'logo') }}" alt="{{ tenant.name }}" class="auth-panel-logo" width="150" height="40">
                {% else %}
                    <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.3rem;font-weight:800;margin-bottom:1.5rem;opacity:.9">{{ tenant.name }}</div>
                {% endif %}
                <h1>Faça parte do nosso time</h1>
                <p style="margin-top:.75rem">Cadastre seu currículo em minutos e seja notado pelo nosso RH quando surgirem oportunidades.</p>
            </div>
            <div class="auth-features">
                <div class="auth-feature"><i class="fa-solid fa-bolt"></i> Cadastro rápido em menos de 2 minutos</div>
                <div class="auth-feature"><i class="fa-solid fa-shield-halved"></i> Dados protegidos conforme a LGPD</div>
                <div class="auth-feature"><i class="fa-solid fa-pen-to-square"></i> Atualize seu perfil quando quiser</div>
            </div>
        </div>

        <div class="auth-panel-right">
            <div style="margin-bottom:1.5rem">
                <h2 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.35rem;font-weight:800;color:var(--text)">Criar conta</h2>
                <p style="font-size:.84rem;color:var(--muted);margin-top:.35rem">
                    Já tem conta? <a href="{{ path('pub_candidate_login') }}" style="color:var(--p);font-weight:600;text-decoration:none">Faça login</a>
                </p>
            </div>

            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'success' ? 'success' : 'error' }}">
                        <i class="fa-solid fa-{{ type == 'success' ? 'circle-check' : 'circle-exclamation' }}"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
            {{ form_errors(form) }}

            <div style="display:flex;flex-direction:column;gap:.1rem">
                <div class="form-group">
                    <label class="form-label">{{ form_label(form.name) }}</label>
                    {{ form_widget(form.name, {attr: {class: 'form-control', placeholder: 'Seu nome completo'}}) }}
                    {{ form_errors(form.name) }}
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">E-mail</label>
                        {{ form_widget(form.email, {attr: {class: 'form-control', placeholder: 'seu@email.com'}}) }}
                        {{ form_errors(form.email) }}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Telefone / WhatsApp</label>
                        {{ form_widget(form.phone, {attr: {class: 'form-control', placeholder: '(11) 99999-9999'}}) }}
                        {{ form_errors(form.phone) }}
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Cidade</label>
                        {{ form_widget(form.city, {attr: {class: 'form-control', placeholder: 'São Paulo'}}) }}
                        {{ form_errors(form.city) }}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Estado (UF)</label>
                        {{ form_widget(form.state, {attr: {class: 'form-control', maxlength: '2', placeholder: 'SP'}}) }}
                        {{ form_errors(form.state) }}
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Senha</label>
                        <div style="position:relative">
                            {{ form_widget(form.plainPassword.first, {attr: {class: 'form-control', placeholder: 'Mínimo 8 caracteres', style: 'padding-right:40px'}}) }}
                            <button type="button" onclick="togglePwd('{{ form.plainPassword.first.vars.id }}',this)"
                                    style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;font-size:.9rem;padding:0">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword.first) }}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirmar senha</label>
                        <div style="position:relative">
                            {{ form_widget(form.plainPassword.second, {attr: {class: 'form-control', placeholder: 'Repita a senha', style: 'padding-right:40px'}}) }}
                            <button type="button" onclick="togglePwd('{{ form.plainPassword.second.vars.id }}',this)"
                                    style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;font-size:.9rem;padding:0">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword.second) }}
                    </div>
                </div>

                <div class="form-group" style="margin-top:.25rem">
                    <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;font-size:.82rem;color:var(--text2)">
                        {{ form_widget(form.lgpdConsent, {attr: {style: 'accent-color:var(--p);margin-top:3px;flex-shrink:0'}}) }}
                        <span>Li e aceito os <a href="{{ path('pub_terms') }}" target="_blank" style="color:var(--p);text-decoration:underline">termos de uso</a> e a <a href="{{ path('pub_privacy') }}" target="_blank" style="color:var(--p);text-decoration:underline">política de privacidade</a>, autorizando o uso dos meus dados conforme a LGPD.</span>
                    </label>
                    {{ form_errors(form.lgpdConsent) }}
                </div>

                <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:.5rem">
                    <i class="fa-solid fa-user-plus"></i>
                    Criar minha conta
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function togglePwd(id, btn) {
    const input = document.getElementById(id);
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    btn.querySelector('i').className = isHidden ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
}
</script>
{% endblock %}
