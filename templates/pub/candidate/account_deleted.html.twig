{% extends 'pub/base.html.twig' %}
{% block title %}Conta Excluída{% endblock %}

{% block body %}
<div class="pub-page-auth">
    <div style="max-width:480px;text-align:center">
        <div style="width:72px;height:72px;border-radius:50%;background:#f0fdf4;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
            <i class="fa-solid fa-check" style="font-size:1.5rem;color:#15803d"></i>
        </div>
        <h1 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.5rem;font-weight:800;margin-bottom:.75rem;color:var(--text)">
            Conta excluída com sucesso
        </h1>
        <p style="font-size:.92rem;color:var(--muted);line-height:1.7;margin-bottom:2rem">
            Todos os seus dados pessoais e arquivos foram removidos da nossa base de dados conforme a LGPD.
            Agradecemos por ter feito parte do nosso banco de talentos.
        </p>
        <a href="{{ path('pub_home') }}" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-arrow-left"></i>
            Voltar para a página inicial
        </a>
    </div>
</div>
{% endblock %}
