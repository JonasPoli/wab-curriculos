{% macro sidebar_link(route, icon, label, current_route) %}
<a href="{{ path(route) }}" class="{{ app.request.get('_route') == route ? 'active' : '' }}">
    <i class="fa-solid fa-{{ icon }}"></i> {{ label }}
</a>
{% endmacro %}

{% extends 'pub/base.html.twig' %}
{% block title %}Minha Conta{% endblock %}

{% block body %}
<div class="pub-layout">

    <aside>
        <div class="pub-card" style="padding:1.25rem">
            <div style="text-align:center;padding:.75rem 0 1rem">
                <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--pub-primary,#0044cc),#7c3aed);color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:700;margin:0 auto .75rem">
                    {{ candidate.name|first|upper }}
                </div>
                <div style="font-weight:700;font-size:.9rem">{{ candidate.name }}</div>
                <div style="font-size:.75rem;color:#64748b;margin-top:2px">{{ candidate.email }}</div>
            </div>

            <nav class="pub-sidebar-menu">
                <a href="{{ path('pub_candidate_dashboard') }}" class="{{ app.request.get('_route') == 'pub_candidate_dashboard' ? 'active' : '' }}">
                    <i class="fa-solid fa-house"></i> Início
                </a>
                <a href="{{ path('pub_candidate_profile') }}" class="{{ app.request.get('_route') starts with 'pub_candidate_profile' ? 'active' : '' }}">
                    <i class="fa-solid fa-user"></i> Dados pessoais
                </a>
                <a href="{{ path('pub_candidate_experience') }}" class="{{ app.request.get('_route') starts with 'pub_candidate_experience' ? 'active' : '' }}">
                    <i class="fa-solid fa-briefcase"></i> Experiências
                </a>
                <a href="{{ path('pub_candidate_academic') }}" class="{{ app.request.get('_route') starts with 'pub_candidate_academic' ? 'active' : '' }}">
                    <i class="fa-solid fa-graduation-cap"></i> Formação
                </a>
                <a href="{{ path('pub_candidate_availability') }}" class="{{ app.request.get('_route') starts with 'pub_candidate_availability' ? 'active' : '' }}">
                    <i class="fa-solid fa-calendar-check"></i> Disponibilidade
                </a>
                <a href="{{ path('pub_candidate_access') }}" class="{{ app.request.get('_route') == 'pub_candidate_access' ? 'active' : '' }}">
                    <i class="fa-solid fa-lock"></i> Dados de acesso
                </a>
                <hr style="border:none;border-top:1px solid #e2e8f0;margin:.5rem 0">
                <a href="{{ path('pub_candidate_delete_account') }}" style="color:#dc2626" class="{{ app.request.get('_route') == 'pub_candidate_delete_account' ? 'active' : '' }}">
                    <i class="fa-solid fa-trash"></i> Excluir conta
                </a>
            </nav>
        </div>
    </aside>

    <div>
        {% block content %}{% endblock %}
    </div>
</div>
{% endblock %}
