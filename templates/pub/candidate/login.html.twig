{% extends 'pub/base.html.twig' %}
{% block title %}Entrar{% endblock %}

{% block body %}
<div class="pub-page-auth">
    <div class="auth-card">

        {# ── Painel esquerdo ─────────────────────────────────────────────── #}
        <div class="auth-panel-left">
            <div class="auth-panel-left-content">
                {% if tenant.logo %}
                    <img src="/uploads/tenants/logo/{{ tenant.logo }}" alt="{{ tenant.name }}" class="auth-panel-logo">
                {% else %}
                    <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.3rem;font-weight:800;margin-bottom:1.5rem;opacity:.9">
                        {{ tenant.name }}
                    </div>
                {% endif %}

                <h1>Acesse sua conta de candidato</h1>
                <p style="margin-top:.75rem">Gerencie seu currículo, acompanhe seu cadastro e seja encontrado pelo RH.</p>
            </div>

            <div class="auth-features">
                <div class="auth-feature">
                    <i class="fa-solid fa-shield-halved"></i>
                    Dados protegidos conforme a LGPD
                </div>
                <div class="auth-feature">
                    <i class="fa-solid fa-pen-to-square"></i>
                    Atualize seu perfil a qualquer momento
                </div>
                <div class="auth-feature">
                    <i class="fa-solid fa-circle-xmark"></i>
                    Exclusão completa dos dados garantida
                </div>
            </div>
        </div>

        {# ── Painel direito ──────────────────────────────────────────────── #}
        <div class="auth-panel-right">
            <div style="margin-bottom:1.75rem">
                <h2 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.35rem;font-weight:800;color:var(--text)">
                    Bem-vindo de volta
                </h2>
                <p style="font-size:.84rem;color:var(--muted);margin-top:.35rem">
                    Não tem conta?
                    <a href="{{ path('pub_candidate_register') }}" style="color:var(--p);font-weight:600;text-decoration:none">Cadastre-se gratuitamente</a>
                </p>
            </div>

            {% if error %}
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" action="{{ path('pub_candidate_login') }}">
                <div class="form-group">
                    <label class="form-label" for="email">E-mail</label>
                    <input class="form-control" type="email" id="email" name="_email"
                           value="{{ last_username }}" autofocus required
                           placeholder="seu@email.com">
                </div>

                <div class="form-group">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                        <label class="form-label" for="password" style="margin:0">Senha</label>
                        <a href="{{ path('pub_candidate_forgot_password') }}"
                           style="font-size:.78rem;color:var(--p);text-decoration:none;font-weight:500">
                            Esqueceu a senha?
                        </a>
                    </div>
                    <div style="position:relative">
                        <input class="form-control" type="password" id="password" name="_password"
                               required placeholder="Mínimo 8 caracteres" style="padding-right:40px">
                        <button type="button" onclick="togglePwd('password',this)"
                                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;font-size:.9rem;padding:0">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:.5rem">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Entrar na minha conta
                </button>
            </form>

            <div class="divider">ou</div>

            <a href="{{ path('pub_candidate_register') }}" class="btn btn-secondary btn-full">
                <i class="fa-solid fa-user-plus"></i>
                Criar nova conta
            </a>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function togglePwd(id, btn) {
    const input = document.getElementById(id);
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    btn.querySelector('i').className = isHidden ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
}
</script>
{% endblock %}
