<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Trabalhe Conosco{% endblock %}{% if tenant is defined and tenant %} · {{ tenant.name }}{% endif %}</title>
    <meta name="description" content="{% block description %}Cadastre seu currículo e faça parte do nosso time.{% endblock %}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    {{ encore_entry_link_tags('app') }}

    <style>
        /* ── Design Tokens ─────────────────────────────────────────────────── */
        :root {
            --p:  {{ (tenant is defined and tenant and tenant.primaryColor) ? tenant.primaryColor : '#0044cc' }};
            --s:  {{ (tenant is defined and tenant and tenant.secondaryColor) ? tenant.secondaryColor : '#f59e0b' }};
            --p-dark: color-mix(in srgb, var(--p) 75%, #000);
            --p-light: color-mix(in srgb, var(--p) 12%, #fff);
            --p-rgb: 0, 68, 204;

            --bg:      #f0f4f8;
            --surface: #ffffff;
            --surface2: #f8fafc;
            --border:  #e2e8f0;
            --text:    #0f172a;
            --muted:   #64748b;
            --radius:  12px;
            --shadow-sm: 0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.05);
            --shadow-md: 0 4px 16px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.05);
            --shadow-lg: 0 12px 40px rgba(0,0,0,.12), 0 4px 12px rgba(0,0,0,.07);
        }

        /* ── Reset ────────────────────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Header ───────────────────────────────────────────────────────── */
        .pub-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--surface);
            border-bottom: 3px solid var(--p);
            box-shadow: var(--shadow-md);
        }
        .pub-header-inner {
            max-width: 1080px;
            margin: 0 auto;
            padding: 0 1.5rem;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }
        .pub-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 1.1rem;
            color: var(--p);
            letter-spacing: -.02em;
        }
        .pub-brand img { height: 38px; object-fit: contain; }
        .pub-brand-icon {
            width: 38px; height: 38px;
            border-radius: 10px;
            background: var(--p);
            color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-size: .95rem;
        }
        .pub-nav {
            display: flex; align-items: center; gap: 6px;
        }
        .pub-nav a {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 7px 14px;
            border-radius: 8px;
            font-size: .82rem;
            font-weight: 600;
            text-decoration: none;
            color: var(--muted);
            transition: all .2s;
        }
        .pub-nav a:hover { color: var(--p); background: var(--p-light); }
        .pub-nav .nav-cta {
            background: var(--p);
            color: #fff !important;
            padding: 8px 18px;
        }
        .pub-nav .nav-cta:hover { opacity: .88; background: var(--p) !important; }
        .pub-nav .nav-logout {
            border: 1.5px solid var(--border);
            color: var(--muted) !important;
        }

        /* ── Main / Footer ────────────────────────────────────────────────── */
        .pub-main { flex: 1; }
        .pub-footer {
            background: #0f172a;
            color: rgba(255,255,255,.45);
            text-align: center;
            padding: 20px;
            font-size: .78rem;
            margin-top: auto;
        }
        .pub-footer a { color: rgba(255,255,255,.6); text-decoration: none; }

        /* ── Layout ───────────────────────────────────────────────────────── */
        .pub-layout {
            max-width: 1080px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
            display: grid;
            grid-template-columns: 240px 1fr;
            gap: 1.5rem;
            align-items: start;
        }

        /* ── Sidebar ──────────────────────────────────────────────────────── */
        .pub-sidebar {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            border: 1px solid var(--border);
        }
        .pub-sidebar-head {
            background: linear-gradient(135deg, var(--p), var(--p-dark));
            padding: 1.5rem 1.25rem;
            text-align: center;
        }
        .pub-avatar {
            width: 60px; height: 60px;
            border-radius: 50%;
            background: rgba(255,255,255,.2);
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 1.4rem;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto .75rem;
            border: 3px solid rgba(255,255,255,.3);
        }
        .pub-sidebar-name {
            color: #fff;
            font-weight: 700;
            font-size: .9rem;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        .pub-sidebar-email { color: rgba(255,255,255,.7); font-size: .75rem; margin-top: 2px; }
        .pub-sidebar-nav { padding: .75rem; }
        .pub-sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 8px;
            font-size: .84rem;
            font-weight: 500;
            text-decoration: none;
            color: var(--muted);
            transition: all .18s;
            margin-bottom: 2px;
        }
        .pub-sidebar-nav a i { width: 16px; text-align: center; font-size: .85rem; flex-shrink: 0; }
        .pub-sidebar-nav a:hover { background: var(--p-light); color: var(--p); }
        .pub-sidebar-nav a.active { background: var(--p); color: #fff; font-weight: 600; }
        .pub-sidebar-nav a.danger { color: #dc2626; }
        .pub-sidebar-nav a.danger:hover { background: #fef2f2; color: #b91c1c; }
        .pub-sidebar-divider { height: 1px; background: var(--border); margin: .5rem 0; }

        /* ── Cards ────────────────────────────────────────────────────────── */
        .card {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            padding: 1.5rem;
            margin-bottom: 1.25rem;
        }
        .card-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700;
            font-size: .95rem;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1.25rem;
        }
        .card-title i { color: var(--p); font-size: .9rem; }

        /* ── Form Elements ────────────────────────────────────────────────── */
        .form-group { margin-bottom: 1rem; }
        .form-label {
            display: block;
            font-size: .75rem;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-bottom: 5px;
        }
        .form-control,
        .form-group input:not([type=checkbox]):not([type=radio]),
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: .9rem;
            font-family: inherit;
            color: var(--text);
            background: var(--surface);
            transition: border-color .18s, box-shadow .18s;
            outline: none;
            appearance: none;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--p);
            box-shadow: 0 0 0 3px var(--p-light);
        }
        .form-group input[disabled],
        .form-group input:disabled { background: var(--surface2); color: var(--muted); cursor: not-allowed; }
        .form-error { font-size: .75rem; color: #dc2626; margin-top: 4px; }

        /* ── Grid helpers ─────────────────────────────────────────────────── */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }

        /* ── Buttons ──────────────────────────────────────────────────────── */
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 22px;
            border-radius: 8px;
            font-size: .875rem;
            font-weight: 600;
            font-family: 'Plus Jakarta Sans', sans-serif;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s;
        }
        .btn-primary { background: var(--p); color: #fff; }
        .btn-primary:hover { opacity: .88; transform: translateY(-1px); box-shadow: 0 6px 20px color-mix(in srgb, var(--p) 35%, transparent); }
        .btn-secondary { background: var(--surface2); color: var(--muted); border: 1.5px solid var(--border); }
        .btn-secondary:hover { background: var(--border); color: var(--text); }
        .btn-danger { background: #fef2f2; color: #dc2626; border: 1.5px solid #fecaca; }
        .btn-danger:hover { background: #fee2e2; }
        .btn-full { width: 100%; justify-content: center; }
        .btn-lg { padding: 13px 28px; font-size: .95rem; }

        /* ── Badges ───────────────────────────────────────────────────────── */
        .badge {
            display: inline-flex; align-items: center;
            padding: 3px 10px;
            border-radius: 999px;
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .03em;
        }
        .badge-primary { background: var(--p-light); color: var(--p); }
        .badge-success { background: #f0fdf4; color: #15803d; }
        .badge-warning { background: #fffbeb; color: #d97706; }

        /* ── Alerts ───────────────────────────────────────────────────────── */
        .alert {
            display: flex; align-items: center; gap: 10px;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: .875rem;
            margin-bottom: 1rem;
        }
        .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }
        .alert-error   { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; }
        .alert-info    { background: var(--p-light); border: 1px solid color-mix(in srgb, var(--p) 25%, transparent); color: var(--p); }

        /* ── List items ───────────────────────────────────────────────────── */
        .list-item {
            display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
            padding: 1rem 0;
            border-bottom: 1px solid var(--border);
        }
        .list-item:last-child { border-bottom: none; padding-bottom: 0; }

        /* ── Stat cards ───────────────────────────────────────────────────── */
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.25rem;
            display: flex; align-items: center; gap: 14px;
            text-decoration: none;
            color: inherit;
            transition: all .2s;
            box-shadow: var(--shadow-sm);
        }
        .stat-card:hover { border-color: var(--p); box-shadow: 0 4px 20px var(--p-light); transform: translateY(-2px); }
        .stat-icon {
            width: 46px; height: 46px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; flex-shrink: 0;
        }
        .stat-value {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--text);
            line-height: 1;
        }
        .stat-label { font-size: .77rem; font-weight: 600; color: var(--muted); margin-top: 3px; text-transform: uppercase; letter-spacing: .04em; }

        /* ── Checkbox grid ────────────────────────────────────────────────── */
        .check-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; }
        .check-item {
            display: flex; align-items: center; gap: 8px;
            padding: 9px 12px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            cursor: pointer;
            font-size: .84rem;
            font-weight: 500;
            transition: border-color .18s, background .18s;
        }
        .check-item:has(input:checked) { border-color: var(--p); background: var(--p-light); color: var(--p); }
        .check-item input { accent-color: var(--p); }

        /* ── Empty state ──────────────────────────────────────────────────── */
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--muted);
        }
        .empty-state i { font-size: 2.5rem; opacity: .3; margin-bottom: 1rem; display: block; }
        .empty-state p { font-size: .88rem; margin-bottom: 1.25rem; }

        /* ── Responsive ───────────────────────────────────────────────────── */
        @media (max-width: 768px) {
            .pub-layout { grid-template-columns: 1fr; }
            .pub-sidebar { display: none; }
            .grid-2, .grid-3 { grid-template-columns: 1fr; }
            .check-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<header class="pub-header">
    <div class="pub-header-inner">
        <a href="{{ app.user ? path('pub_candidate_dashboard') : path('pub_candidate_login') }}" class="pub-brand">
            {% if tenant is defined and tenant and tenant.logo %}
                <img src="/uploads/tenants/logo/{{ tenant.logo }}" alt="{{ tenant.name }}">
            {% else %}
                <div class="pub-brand-icon"><i class="fa-solid fa-briefcase"></i></div>
                <span>{% if tenant is defined and tenant %}{{ tenant.name }}{% else %}Trabalhe Conosco{% endif %}</span>
            {% endif %}
        </a>

        <nav class="pub-nav">
            {% if app.user %}
                <a href="{{ path('pub_candidate_dashboard') }}"><i class="fa-solid fa-house"></i> Início</a>
                <a href="{{ path('pub_candidate_profile') }}"><i class="fa-solid fa-user"></i> Perfil</a>
                <a href="{{ path('pub_candidate_logout') }}" class="nav-logout"><i class="fa-solid fa-right-from-bracket"></i> Sair</a>
            {% else %}
                <a href="{{ path('pub_candidate_login') }}">Entrar</a>
                <a href="{{ path('pub_candidate_register') }}" class="nav-cta">
                    <i class="fa-solid fa-user-plus"></i> Cadastre-se
                </a>
            {% endif %}
        </nav>
    </div>
</header>

<main class="pub-main">
    {% set _flashes = app.flashes %}
    {% if _flashes %}
    <div style="max-width:1080px;margin:1rem auto;padding:0 1.5rem">
        {% for type, messages in _flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'success' ? 'success' : (type == 'error' ? 'error' : 'info') }}">
                    <i class="fa-solid fa-{{ type == 'success' ? 'circle-check' : (type == 'error' ? 'circle-exclamation' : 'circle-info') }}"></i>
                    {{ message|raw }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>
    {% endif %}

    {% block body %}{% endblock %}
</main>

<footer class="pub-footer">
    {% if tenant is defined and tenant %}
        <strong style="color:rgba(255,255,255,.65)">{{ tenant.name }}</strong> ·
    {% endif %}
    Todos os dados protegidos conforme a LGPD ·
    <a href="{{ path('pub_candidate_delete_account') }}">Excluir minha conta</a> ·
    Powered by <a href="https://wab.com.br" target="_blank">WAB</a>
</footer>

{{ encore_entry_script_tags('app') }}
{% block javascripts %}{% endblock %}
</body>
</html>
