{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}

{% set _tenant = current_tenant() %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            {% if _tenant %}
                <i class="fa-solid fa-building" aria-hidden="true" style="color:var(--bm-accent)"></i>
                {{ _tenant.name }}
            {% else %}
                <i class="fa-solid fa-shield-halved" aria-hidden="true" style="color:var(--bm-accent)"></i>
                Painel Super Admin
            {% endif %}
        </h1>
        <p style="font-size:.85rem;color:var(--bm-text-muted);margin-top:2px">
            Bem-vindo, <strong>{{ app.user.userIdentifier }}</strong> · {{ 'now'|date('d/m/Y') }}
        </p>
    </div>
</div>

{% if _tenant %}

{# ══════════════════════════════════════════════════════════
   DASHBOARD DO TENANT
   ══════════════════════════════════════════════════════════ #}

{# ── Stat Cards ── #}
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px">

    <div class="stat-card">
        <div class="stat-card-icon" style="background:rgba(var(--bm-accent-rgb,79,142,247),.12);color:var(--bm-accent)">
            <i class="fa-solid fa-users" aria-hidden="true"></i>
        </div>
        <div>
            <p class="stat-card-value">{{ stats.candidates_total }}</p>
            <p class="stat-card-label">Candidatos</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-icon" style="background:rgba(16,185,129,.12);color:#059669">
            <i class="fa-solid fa-user-check" aria-hidden="true"></i>
        </div>
        <div>
            <p class="stat-card-value">{{ stats.candidates_active }}</p>
            <p class="stat-card-label">Ativos</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-icon" style="background:rgba(168,85,247,.12);color:#9333ea">
            <i class="fa-solid fa-calendar-plus" aria-hidden="true"></i>
        </div>
        <div>
            <p class="stat-card-value">{{ stats.candidates_new }}</p>
            <p class="stat-card-label">Novos este mês</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-icon" style="background:rgba(245,158,11,.12);color:#d97706">
            <i class="fa-solid fa-sitemap" aria-hidden="true"></i>
        </div>
        <div>
            <p class="stat-card-value">{{ stats.areas_total }}</p>
            <p class="stat-card-label">Áreas de interesse</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-icon" style="background:rgba(6,182,212,.12);color:#0891b2">
            <i class="fa-solid fa-briefcase" aria-hidden="true"></i>
        </div>
        <div>
            <p class="stat-card-value">{{ stats.careers_active }}<span style="font-size:.9rem;color:var(--bm-text-muted);font-weight:500">/{{ stats.careers_total }}</span></p>
            <p class="stat-card-label">Cargos ativos</p>
        </div>
    </div>

</div>

{# ── Conteúdo principal ── #}
<div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start">

    {# Candidatos Recentes #}
    <div class="admin-card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
            <h2 style="font-size:.95rem;font-weight:700;margin:0;display:flex;align-items:center;gap:8px">
                <i class="fa-solid fa-clock-rotate-left" style="color:var(--bm-accent)"></i>
                Candidatos Recentes
            </h2>
            <a href="{{ path('admin_candidate_index') }}" class="btn-secondary" style="padding:4px 12px;font-size:.78rem">
                Ver todos <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>

        {% if stats.recent_candidates is empty %}
            <div style="text-align:center;padding:2rem;color:var(--bm-text-muted)">
                <i class="fa-solid fa-inbox fa-2x" style="margin-bottom:.75rem;opacity:.4"></i>
                <p style="margin:0;font-size:.85rem">Nenhum candidato ainda.</p>
            </div>
        {% else %}
            <div style="display:flex;flex-direction:column;gap:0">
                {% for candidate in stats.recent_candidates %}
                <a href="{{ path('admin_candidate_show', {id: candidate.id}) }}"
                   style="display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:8px;text-decoration:none;color:inherit;transition:background .15s;border-bottom:1px solid var(--bm-border)"
                   onmouseover="this.style.background='var(--bm-hover)'" onmouseout="this.style.background=''"
                   >
                    <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--bm-accent),#a855f7);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:700;flex-shrink:0">
                        {{ candidate.name|first|upper }}
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-weight:600;font-size:.875rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ candidate.name }}</div>
                        <div style="font-size:.75rem;color:var(--bm-text-muted)">{{ candidate.city }}/{{ candidate.state }} · {{ candidate.createdAt|date('d/m/Y') }}</div>
                    </div>
                    {% if candidate.activeRegistration %}
                        <span class="badge badge-green">Ativo</span>
                    {% else %}
                        <span class="badge badge-neutral">Inativo</span>
                    {% endif %}
                </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Coluna lateral #}
    <div style="display:flex;flex-direction:column;gap:16px">

        {# Ações rápidas #}
        <div class="admin-card">
            <h2 style="font-size:.9rem;font-weight:700;margin:0 0 12px;display:flex;align-items:center;gap:8px">
                <i class="fa-solid fa-bolt" style="color:var(--bm-accent)"></i>
                Ações rápidas
            </h2>
            <div style="display:flex;flex-direction:column;gap:6px">
                <a href="{{ path('admin_candidate_index') }}"
                   style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:7px;text-decoration:none;color:var(--bm-text);font-size:.85rem;font-weight:500;transition:background .15s"
                   onmouseover="this.style.background='var(--bm-hover)'" onmouseout="this.style.background=''">
                    <i class="fa-solid fa-users" style="color:var(--bm-accent);width:16px;text-align:center"></i>
                    Ver candidatos
                </a>
                <a href="{{ path('admin_area_of_interest_new') }}"
                   style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:7px;text-decoration:none;color:var(--bm-text);font-size:.85rem;font-weight:500;transition:background .15s"
                   onmouseover="this.style.background='var(--bm-hover)'" onmouseout="this.style.background=''">
                    <i class="fa-solid fa-sitemap" style="color:#d97706;width:16px;text-align:center"></i>
                    Nova área de interesse
                </a>
                <a href="{{ path('admin_career_new') }}"
                   style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:7px;text-decoration:none;color:var(--bm-text);font-size:.85rem;font-weight:500;transition:background .15s"
                   onmouseover="this.style.background='var(--bm-hover)'" onmouseout="this.style.background=''">
                    <i class="fa-solid fa-briefcase" style="color:#0891b2;width:16px;text-align:center"></i>
                    Novo cargo
                </a>
            </div>
        </div>

        {# Info do tenant #}
        <div class="admin-card" style="background:linear-gradient(135deg,var(--bm-accent,#4f8ef7),#a855f7);color:#fff">
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;opacity:.75;margin-bottom:8px">Tenant ativo</div>
            {% if _tenant.logo %}
                <img src="/uploads/tenants/logo/{{ _tenant.logo }}" alt="{{ _tenant.name }}"
                     style="height:40px;max-width:140px;object-fit:contain;filter:brightness(0) invert(1);margin-bottom:10px">
            {% else %}
                <div style="font-size:1.2rem;font-weight:800;margin-bottom:6px">{{ _tenant.name }}</div>
            {% endif %}
            {% if _tenant.contactEmail %}
                <div style="font-size:.78rem;opacity:.85;display:flex;align-items:center;gap:6px">
                    <i class="fa-solid fa-envelope"></i>{{ _tenant.contactEmail }}
                </div>
            {% endif %}
            {% if _tenant.domain %}
                <div style="font-size:.78rem;opacity:.85;display:flex;align-items:center;gap:6px;margin-top:4px">
                    <i class="fa-solid fa-globe"></i>{{ _tenant.domain }}
                </div>
            {% endif %}
        </div>

    </div>

</div>

{% else %}

{# ══════════════════════════════════════════════════════════
   DASHBOARD DO SUPER ADMIN
   ══════════════════════════════════════════════════════════ #}

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px">

    <div class="stat-card">
        <div class="stat-card-icon" style="background:rgba(79,142,247,.12);color:#2563eb">
            <i class="fa-solid fa-building" aria-hidden="true"></i>
        </div>
        <div>
            <p class="stat-card-value">{{ stats.tenants_total }}</p>
            <p class="stat-card-label">Tenants</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-icon" style="background:rgba(16,185,129,.12);color:#059669">
            <i class="fa-solid fa-users" aria-hidden="true"></i>
        </div>
        <div>
            <p class="stat-card-value">{{ stats.candidates_total }}</p>
            <p class="stat-card-label">Candidatos (total)</p>
        </div>
    </div>

</div>

<div style="display:grid;grid-template-columns:1fr 280px;gap:20px">

    <div class="admin-card">
        <h2 style="font-size:.95rem;font-weight:700;margin:0 0 14px;display:flex;align-items:center;gap:8px">
            <i class="fa-solid fa-building" style="color:var(--bm-accent)"></i>
            Gerenciar Tenants
        </h2>
        <p style="font-size:.85rem;color:var(--bm-text-muted);margin:0 0 16px">
            Selecione um tenant na lista abaixo para acessar o painel de gestão com as cores e dados daquela empresa.
        </p>
        <a href="{{ path('admin_tenant_index') }}" class="btn-primary">
            <i class="fa-solid fa-list"></i>
            Ver todos os tenants
        </a>
    </div>

    <div class="admin-card">
        <h2 style="font-size:.9rem;font-weight:700;margin:0 0 12px;display:flex;align-items:center;gap:8px">
            <i class="fa-solid fa-bolt" style="color:var(--bm-accent)"></i>
            Ações rápidas
        </h2>
        <div style="display:flex;flex-direction:column;gap:6px">
            <a href="{{ path('admin_tenant_new') }}"
               style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:7px;text-decoration:none;color:var(--bm-text);font-size:.85rem;font-weight:500;transition:background .15s"
               onmouseover="this.style.background='var(--bm-hover)'" onmouseout="this.style.background=''">
                <i class="fa-solid fa-plus" style="color:var(--bm-accent);width:16px;text-align:center"></i>
                Novo tenant
            </a>
            <a href="{{ path('admin_user_new') }}"
               style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:7px;text-decoration:none;color:var(--bm-text);font-size:.85rem;font-weight:500;transition:background .15s"
               onmouseover="this.style.background='var(--bm-hover)'" onmouseout="this.style.background=''">
                <i class="fa-solid fa-user-plus" style="color:#9333ea;width:16px;text-align:center"></i>
                Novo usuário admin
            </a>
        </div>
    </div>

</div>

{% endif %}

{% endblock %}