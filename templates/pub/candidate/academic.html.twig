{% extends 'pub/candidate/layout.html.twig' %}
{% block title %}Formacao Academica{% endblock %}

{% block content %}

{% if candidate.academicBackgrounds|length > 0 %}
<div class="card" style="margin-bottom:1.25rem">
    <div class="card-title"><i class="fa-solid fa-graduation-cap" style="color:var(--p)"></i> Sua formacao</div>
    {% for ab in candidate.academicBackgrounds %}
    <div class="list-item">
        <div>
            <div style="font-weight:700;font-size:.9rem;color:var(--text)">{{ ab.course }}</div>
            <div style="color:var(--text2);font-size:.85rem">{{ ab.institution }}</div>
            <div style="font-size:.8rem;color:var(--muted)">{{ ab.educationLevel.label }} · {{ ab.status.label }}</div>
            <div style="font-size:.78rem;color:var(--muted);margin-top:3px">
                {{ ab.startDate ? ab.startDate|date('Y') : '' }}
                {% if ab.endDate %} — {{ ab.endDate|date('Y') }}{% endif %}
            </div>
        </div>
        <form method="post" action="{{ path('pub_candidate_academic_delete', {id: ab.id}) }}" onsubmit="return confirm('Remover esta formacao?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_ab_' ~ ab.id) }}">
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="fa-solid fa-trash"></i>
            </button>
        </form>
    </div>
    {% endfor %}
</div>
{% endif %}

<div class="card">
    <div class="card-title"><i class="fa-solid fa-plus" style="color:var(--p)"></i> Adicionar formacao</div>
    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
    <div class="form-row">
        <div class="form-group">
            <label class="form-label">Nivel</label>
            {{ form_widget(form.educationLevel, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.educationLevel) }}
        </div>
        <div class="form-group">
            <label class="form-label">Status</label>
            {{ form_widget(form.status, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.status) }}
        </div>
    </div>
    <div class="form-group">
        <label class="form-label">Instituicao</label>
        {{ form_widget(form.institution, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.institution) }}
    </div>
    <div class="form-group">
        <label class="form-label">Curso</label>
        {{ form_widget(form.course, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.course) }}
    </div>
    <div class="form-row">
        <div class="form-group">
            <label class="form-label">Inicio</label>
            {{ form_widget(form.startDate, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.startDate) }}
        </div>
        <div class="form-group">
            <label class="form-label">Conclusao</label>
            {{ form_widget(form.endDate, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.endDate) }}
        </div>
    </div>
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Adicionar
    </button>
    {{ form_end(form) }}
</div>

{% endblock %}
