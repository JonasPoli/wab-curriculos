{% extends 'admin/base.html.twig' %}

{% block title %}Candidatos{% endblock %}

{% block breadcrumbs %}
    {% set breadcrumbs = [
        { label: 'Dashboard', route: 'admin_dash' },
        { label: 'Candidatos', route: null }
    ] %}
    {{ include('admin/_partials/breadcrumbs.html.twig', { breadcrumbs: breadcrumbs }) }}
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.dataTables.min.css">
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.css" rel="stylesheet">
    <style>
        /* Premium custom styles for TomSelect */
        .ts-wrapper.multi .ts-control {
            border: 1.5px solid var(--bm-border) !important;
            border-radius: 8px !important;
            background: var(--bm-bg) !important;
            color: var(--bm-text) !important;
            padding: 8px 12px !important;
            font-size: .82rem !important;
            font-family: inherit !important;
            box-shadow: none !important;
            transition: border-color .15s !important;
        }
        .ts-wrapper.multi.focus .ts-control {
            border-color: var(--bm-accent) !important;
            box-shadow: 0 0 0 3px rgba(var(--bm-accent-rgb, 99,102,241), .12) !important;
        }
        .ts-dropdown {
            background: var(--bm-surface, #ffffff) !important;
            color: var(--bm-text) !important;
            border: 1px solid var(--bm-border) !important;
            border-radius: 8px !important;
            box-shadow: var(--bm-shadow-lg) !important;
            font-size: .82rem !important;
            z-index: 1000 !important;
        }
        .ts-dropdown .active {
            background-color: var(--bm-accent) !important;
            color: #ffffff !important;
        }
        .ts-dropdown .option:hover {
            background-color: color-mix(in srgb, var(--bm-accent) 15%, transparent) !important;
            color: var(--bm-text) !important;
        }
        .ts-control .item {
            background: var(--bm-accent) !important;
            color: #ffffff !important;
            border-radius: 4px !important;
            font-weight: 500 !important;
            padding: 2px 6px !important;
            border: none !important;
        }
        .ts-control .item .remove {
            border-left: 1px solid rgba(255, 255, 255, 0.3) !important;
            color: #ffffff !important;
        }
        /* Fix styles in dark mode */
        html.dark .ts-wrapper.multi .ts-control {
            background: var(--bm-input-bg) !important;
            border-color: var(--bm-input-border) !important;
        }
        html.dark .ts-dropdown {
            background: var(--bm-card-bg) !important;
            border-color: var(--bm-border) !important;
        }
        html.dark .ts-dropdown .option {
            color: var(--bm-text) !important;
        }
        html.dark .ts-dropdown .option.active {
            background-color: var(--bm-accent) !important;
            color: #ffffff !important;
        }

        .filter-panel {
            background: var(--bm-surface);
            border: 1px solid var(--bm-border);
            border-radius: 12px;
            margin-bottom: 1.5rem;
            overflow: hidden;
        }
        .filter-panel-header {
            padding: .9rem 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            user-select: none;
            gap: 12px;
        }
        .filter-panel-header:hover { background: var(--bm-surface-hover); }
        .filter-panel-title {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: .875rem;
            color: var(--bm-text);
        }
        .filter-badge {
            background: var(--bm-accent);
            color: #fff;
            border-radius: 999px;
            padding: 2px 9px;
            font-size: .72rem;
            font-weight: 700;
        }
        .filter-panel-body {
            padding: 1.25rem;
            border-top: 1px solid var(--bm-border);
            display: none;
        }
        .filter-panel-body.open { display: block; }
        .filter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: .75rem;
            margin-bottom: 1rem;
        }
        .filter-grid .filter-full { grid-column: 1 / -1; }
        .filter-input, .filter-select {
            width: 100%;
            padding: 8px 12px;
            border: 1.5px solid var(--bm-border);
            border-radius: 8px;
            font-size: .82rem;
            font-family: inherit;
            color: var(--bm-text);
            background: var(--bm-bg);
            outline: none;
            transition: border-color .15s;
        }
        .filter-input:focus, .filter-select:focus {
            border-color: var(--bm-accent);
            box-shadow: 0 0 0 3px rgba(var(--bm-accent-rgb, 99,102,241), .12);
        }
        .filter-actions {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding-top: .75rem;
            border-top: 1px solid var(--bm-border);
        }
        .filter-count-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: .78rem;
            font-weight: 600;
            background: color-mix(in srgb, var(--bm-accent) 12%, transparent);
            color: var(--bm-accent);
        }
        .result-summary {
            font-size: .82rem;
            color: var(--bm-text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        .result-summary strong { color: var(--bm-text); }

        /* Availability dots */
        .avail-grid {
            display: inline-flex;
            gap: 3px;
        }
        .avail-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: #e2e8f0;
        }
        .avail-dot.on { background: #22c55e; }
    </style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-users" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Candidatos
        </h1>
        <p class="page-subtitle result-summary">
            {% if activeFilters > 0 %}
                <span class="filter-count-tag">
                    <i class="fa-solid fa-filter"></i>
                    {{ activeFilters }} filtro{% if activeFilters > 1 %}s{% endif %} ativo{% if activeFilters > 1 %}s{% endif %}
                </span>
                <strong>{{ candidates|length }}</strong> resultado{% if candidates|length != 1 %}s{% endif %}
                de <strong>{{ totalAll }}</strong> no total
                · <a href="{{ path('admin_candidate_index') }}" style="color:var(--bm-accent)">Limpar filtros</a>
            {% else %}
                <strong>{{ candidates|length }}</strong> candidato{% if candidates|length != 1 %}s{% endif %} cadastrado{% if candidates|length != 1 %}s{% endif %}
            {% endif %}
        </p>
    </div>
</div>

{# ── Pesquisas Salvas ──────────────────────────────────────────────────── #}
{% if savedSearches is defined and savedSearches|length > 0 %}
<div style="margin-bottom:1rem;display:flex;flex-wrap:wrap;gap:.5rem;align-items:center">
    <span style="font-size:.8rem;font-weight:600;color:var(--bm-text-muted);margin-right:.25rem">
        <i class="fa-solid fa-bookmark" style="margin-right:4px"></i>Pesquisas salvas:
    </span>
    {% for search in savedSearches %}
        <span style="display:inline-flex;align-items:center;gap:4px;background:color-mix(in srgb, var(--bm-accent) 10%, transparent);border:1px solid color-mix(in srgb, var(--bm-accent) 25%, transparent);border-radius:999px;padding:3px 6px 3px 12px;font-size:.78rem;font-weight:600;color:var(--bm-accent)">
            <a href="{{ path('admin_candidate_index', search.filters) }}" style="color:inherit;text-decoration:none">
                {{ search.name }}
            </a>
            <form method="post" action="{{ path('admin_candidate_delete_search', {id: search.id}) }}" style="display:inline;margin:0">
                <button type="submit" style="background:none;border:none;cursor:pointer;color:var(--bm-text-muted);padding:2px 4px;font-size:.7rem;line-height:1" title="Remover pesquisa">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </form>
        </span>
    {% endfor %}
</div>
{% endif %}

{# ── Painel de Filtros ────────────────────────────────────────────────────── #}
{{ form_start(filterForm, {
    attr: { id: 'filter-form', novalidate: 'novalidate' },
    action: path('admin_candidate_index'),
    method: 'GET'
}) }}
<div class="filter-panel">
    <div class="filter-panel-header" id="filter-toggle">
        <div class="filter-panel-title">
            <i class="fa-solid fa-sliders" style="color:var(--bm-accent)"></i>
            Filtros e Busca
            {% if activeFilters > 0 %}
                <span class="filter-badge">{{ activeFilters }} ativo{% if activeFilters > 1 %}s{% endif %}</span>
            {% endif %}
        </div>
        <i class="fa-solid fa-chevron-down" id="filter-chevron" style="color:var(--bm-text-muted);font-size:.8rem;transition:transform .2s"></i>
    </div>

    <div class="filter-panel-body {% if activeFilters > 0 %}open{% endif %}" id="filter-body">

        <div class="filter-grid">
            {# Busca textual #}
            <div class="filter-full" style="display: flex; gap: 8px;">
                <div style="flex: 1;">
                    {{ form_widget(filterForm.q, {attr: {class: 'filter-input'}}) }}
                </div>
                <div style="width: 220px; flex-shrink: 0;">
                    {{ form_widget(filterForm.qMode, {attr: {class: 'filter-select'}}) }}
                </div>
            </div>

            {# Área de interesse #}
            <div>
                <label style="display:block;font-size:.74rem;font-weight:600;color:var(--bm-text-muted);margin-bottom:5px">Áreas de Interesse</label>
                {{ form_widget(filterForm.area, {attr: {class: 'filter-select'}}) }}
            </div>

            {# Cargo #}
            <div>
                <label style="display:block;font-size:.74rem;font-weight:600;color:var(--bm-text-muted);margin-bottom:5px">Cargos</label>
                {{ form_widget(filterForm.career, {attr: {class: 'filter-select'}}) }}
            </div>

            {# Estado #}
            <div>
                <label style="display:block;font-size:.74rem;font-weight:600;color:var(--bm-text-muted);margin-bottom:5px">Estados (UF)</label>
                {{ form_widget(filterForm.state, {attr: {class: 'filter-select'}}) }}
            </div>

            {# Tipo de contrato #}
            <div>
                <label style="display:block;font-size:.74rem;font-weight:600;color:var(--bm-text-muted);margin-bottom:5px">Tipos de Contrato</label>
                {{ form_widget(filterForm.contractType, {attr: {class: 'filter-select'}}) }}
            </div>

            {# Início imediato #}
            <div>
                <label style="display:block;font-size:.74rem;font-weight:600;color:var(--bm-text-muted);margin-bottom:5px">Início Imediato</label>
                {{ form_widget(filterForm.immediateStart, {attr: {class: 'filter-select'}}) }}
            </div>

            {# PDF #}
            <div>
                <label style="display:block;font-size:.74rem;font-weight:600;color:var(--bm-text-muted);margin-bottom:5px">PDF Currículo</label>
                {{ form_widget(filterForm.hasResume, {attr: {class: 'filter-select'}}) }}
            </div>

            {# Datas #}
            <div>
                <label style="display:block;font-size:.74rem;font-weight:600;color:var(--bm-text-muted);margin-bottom:5px">Cadastrado de</label>
                {{ form_widget(filterForm.dateFrom, {attr: {class: 'filter-input', type: 'date'}}) }}
            </div>
            <div>
                <label style="display:block;font-size:.74rem;font-weight:600;color:var(--bm-text-muted);margin-bottom:5px">Cadastrado até</label>
                {{ form_widget(filterForm.dateTo, {attr: {class: 'filter-input', type: 'date'}}) }}
            </div>
        </div>

        <div class="filter-actions">
            <button type="submit" class="btn-primary">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                Buscar
            </button>
            {% if activeFilters > 0 %}
            <a href="{{ path('admin_candidate_index') }}" class="btn-secondary">
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                Limpar filtros
            </a>
            {% endif %}
            <a href="{{ path('admin_candidate_export_csv', app.request.query.all) }}" class="btn-secondary">
                <i class="fa-solid fa-file-csv" aria-hidden="true"></i>
                Exportar CSV
            </a>
        </div>

        {% if activeFilters > 0 %}
        <div style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--bm-border);display:flex;align-items:center;gap:.5rem">
            <form method="post" action="{{ path('admin_candidate_save_search') }}" style="display:flex;align-items:center;gap:.5rem;flex:1">
                {% for key, value in currentFilters %}
                    {% if value is iterable %}
                        {% for v in value %}
                            <input type="hidden" name="filters[{{ key }}][]" value="{{ v }}">
                        {% endfor %}
                    {% else %}
                        <input type="hidden" name="filters[{{ key }}]" value="{{ value }}">
                    {% endif %}
                {% endfor %}
                <input type="text" name="search_name" placeholder="Nome da pesquisa..." required
                       style="padding:6px 10px;border:1.5px solid var(--bm-border);border-radius:7px;font-size:.8rem;font-family:inherit;color:var(--bm-text);background:var(--bm-bg);outline:none;flex:1;max-width:220px">
                <button type="submit" class="btn-secondary" style="padding:6px 12px;font-size:.78rem">
                    <i class="fa-solid fa-bookmark" aria-hidden="true"></i>
                    Salvar pesquisa
                </button>
            </form>
        </div>
        {% endif %}

    </div>
</div>
{{ form_end(filterForm) }}

{# ── Tabela ───────────────────────────────────────────────────────────────── #}
<div class="card">
    <div class="card-body">
        <div class="responsive-table">
            <table id="candidates-table" class="display nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nome</th>
                    <th>Contato / Localização</th>
                    <th>Cargos de interesse</th>
                    <th>Disponibilidade</th>
                    <th>Cadastrado em</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for candidate in candidates %}
                <tr>
                    <td>{{ candidate.id }}</td>
                    <td data-export="{{ candidate.name }}">
                        <div style="display:flex;align-items:center;gap:10px">
                            <div style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--bm-accent),#7c3aed);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0">
                                {{ candidate.name|first|upper }}
                            </div>
                            <div style="display:flex; flex-direction:column; gap:4px">
                                <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap">
                                    <strong style="font-size:.875rem">{{ candidate.name }}</strong>
                                    {% if candidate.resumeFilename %}
                                        <a href="{{ path('admin_candidate_download_resume', {id: candidate.id}) }}"
                                           title="Baixar currículo PDF" target="_blank" style="color:var(--bm-danger);font-size:.85rem;text-decoration:none;display:inline-flex;align-items:center"
                                           onclick="event.stopPropagation();">
                                            <i class="fa-solid fa-file-pdf"></i>
                                        </a>
                                    {% endif %}
                                </div>
                                <div style="display:flex; align-items:center; gap:4px; flex-wrap:wrap">
                                    {% if candidate.immediateStart %}
                                        <span class="badge" style="background:#dcfce7;color:#15803d;font-size:.65rem">Início imediato</span>
                                    {% endif %}
                                    {% if candidate.contractTypes %}
                                        {% for ct in candidate.contractTypes %}
                                            <span class="badge" style="background:var(--bm-border);color:var(--bm-text);font-size:.65rem;text-transform:uppercase">{{ ct }}</span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div style="font-size:.82rem;line-height:1.5">
                            <a href="mailto:{{ candidate.email }}" style="color:var(--bm-accent);text-decoration:none">{{ candidate.email }}</a><br>
                            <span style="color:var(--bm-text-muted)">{{ candidate.phone }}</span><br>
                            <span style="font-size:.78rem;color:var(--bm-text-muted);display:inline-flex;align-items:center;gap:4px">
                                <i class="fa-solid fa-location-dot" style="font-size:.7rem"></i>
                                {{ candidate.city }}/{{ candidate.state }}
                            </span>
                        </div>
                    </td>
                    <td data-export="{% for career in candidate.careers %}{{ career.title }}{% if not loop.last %}, {% endif %}{% endfor %}">
                        {% if candidate.careers|length > 0 %}
                            <div style="display:flex; flex-direction:column; gap:4px; align-items:flex-start">
                                {% for career in candidate.careers|slice(0, 2) %}
                                    <span class="badge badge-blue" style="font-size:.7rem; white-space:nowrap">{{ career.title }}</span>
                                  {% endfor %}
                                {% if candidate.careers|length > 2 %}
                                    <span class="badge" style="background:rgba(100,116,139,.15);color:var(--bm-text-muted);font-size:.7rem">+{{ candidate.careers|length - 2 }}</span>
                                  {% endif %}
                              </div>
                          {% else %}
                            <span style="font-size:.75rem;opacity:.4">—</span>
                          {% endif %}
                    </td>
                    <td data-export="{{ candidate.availabilityText }}">
                        {# Grade de disponibilidade: Seg–Sex, Manhã/Tarde #}
                        {% set grid = candidate.availabilityGrid %}
                        <div class="avail-grid" title="Disponibilidade semanal">
                            {% for day, slots in grid %}
                                <div class="avail-dot {{ slots.morning ? 'on' : '' }}" title="{{ day }} manhã"></div>
                                <div class="avail-dot {{ slots.afternoon ? 'on' : '' }}" title="{{ day }} tarde"></div>
                            {% endfor %}
                        </div>
                    </td>
                    <td>{{ candidate.createdAt ? candidate.createdAt|date('d/m/Y') : '—' }}</td>
                    <td>
                        <a href="{{ path('admin_candidate_show', {id: candidate.id}) }}" class="btn-secondary" title="Ver detalhes" style="padding:5px 10px">
                            <i class="fa-solid fa-eye" aria-hidden="true"></i>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" style="text-align:center;padding:64px 32px">
                        <i class="fa-solid fa-users-slash" style="font-size:2.5rem;opacity:.2;display:block;margin-bottom:1rem"></i>
                        {% if activeFilters > 0 %}
                            Nenhum candidato encontrado com os filtros aplicados.
                            <br><a href="{{ path('admin_candidate_index') }}" style="color:var(--bm-accent);margin-top:.5rem;display:inline-block">Limpar filtros</a>
                        {% else %}
                            Nenhum candidato cadastrado ainda.
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/3.0.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdn.datatables.net/buttons/3.0.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
<script>
    {% if candidates|length > 0 %}
    new DataTable('#candidates-table', {
        language: { url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json' },
        pageLength: 25,
        order: [[5, 'desc']],
        layout: {
            topStart: {
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: '<i class="fa-solid fa-file-excel"></i> Exportar Excel',
                        className: 'btn-secondary',
                        exportOptions: {
                            columns: [0, 1, 2, 3, 4, 5],
                            format: {
                                body: function (data, row, column, node) {
                                    if (node.hasAttribute('data-export')) {
                                        return node.getAttribute('data-export');
                                    }
                                    return node.textContent.trim().replace(/\s+/g, ' ');
                                }
                            }
                        }
                    }
                ]
            }
        },
        columnDefs: [{ orderable: false, targets: [3, 4, 6] }]
    });
    {% endif %}

    // Toggle do painel de filtros
    const toggle = document.getElementById('filter-toggle');
    const body   = document.getElementById('filter-body');
    const chev   = document.getElementById('filter-chevron');

    toggle.addEventListener('click', () => {
        body.classList.toggle('open');
        chev.style.transform = body.classList.contains('open') ? 'rotate(180deg)' : '';
    });

    // Auto-submit apenas nos selects de filtro não múltiplos
    document.querySelectorAll('#filter-form select:not([multiple])').forEach(sel => {
        sel.addEventListener('change', () => document.getElementById('filter-form').submit());
    });

    // Inicialização do TomSelect para campos de seleção múltipla
    const tomSelects = [];
    document.querySelectorAll('#filter-form select[multiple]').forEach(sel => {
        let placeholder = 'Selecione...';
        if (sel.name.includes('area')) placeholder = 'Selecionar áreas...';
        else if (sel.name.includes('career')) placeholder = 'Selecionar cargos...';
        else if (sel.name.includes('state')) placeholder = 'Selecionar estados...';
        else if (sel.name.includes('contractType')) placeholder = 'Selecionar contratos...';

        const ts = new TomSelect(sel, {
            plugins: ['remove_button'],
            placeholder: placeholder,
            maxItems: null,
            create: false,
            hideSelected: true,
        });
        tomSelects.push(ts);
    });

    // Limpeza do TomSelect antes do Turbo cachear a página
    document.addEventListener('turbo:before-cache', () => {
        tomSelects.forEach(ts => {
            try { ts.destroy(); } catch(e) {}
        });
    });
</script>
{% endblock %}
