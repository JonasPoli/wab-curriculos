<!DOCTYPE html>
<html lang="pt-BR" class="">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Esqueci a senha · Administração</title>
    <link rel="icon" href="/images/fav.png">

    {# Google Fonts — Inter #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">

    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          crossorigin="anonymous" referrerpolicy="no-referrer">
    {{ importmap('app') }}

    {# Anti-FOUC dark mode #}
    <script>
        (function () {
            var theme = localStorage.theme;
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (theme === 'dark' || (!theme && prefersDark)) {
                document.documentElement.classList.add('dark', 'wa-dark');
                document.documentElement.classList.remove('wa-light');
            } else {
                document.documentElement.classList.remove('dark', 'wa-dark');
                document.documentElement.classList.add('wa-light');
            }
        })();
    </script>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-100 via-slate-50 to-white dark:from-slate-950 dark:via-slate-900 dark:to-slate-800 text-slate-800 dark:text-white antialiased flex items-center justify-center p-4">

    {# Background decorative elements #}
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/10 dark:bg-primary/5 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-indigo-500/10 dark:bg-indigo-500/5 rounded-full blur-3xl"></div>
    </div>

    <main class="relative w-full max-w-md" id="main-content">

        {# Card #}
        <div class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border border-slate-200/80 dark:border-white/10 rounded-2xl shadow-2xl shadow-slate-900/10 dark:shadow-black/40 p-8 md:p-10">

            {# Brand icon #}
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl mb-4"
                     style="background: linear-gradient(135deg, #4f8ef7, #a855f7); box-shadow: 0 8px 24px rgba(79,142,247,.35)">
                    <i class="fa-solid fa-key text-white text-2xl" aria-hidden="true"></i>
                </div>

                {% if success %}
                    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">E-mail enviado!</h1>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Verifique sua caixa de entrada</p>
                {% else %}
                    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Esqueci a senha</h1>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Enviaremos um link de redefinição</p>
                {% endif %}
            </div>

            {% if success %}
                {# ── Estado de sucesso ────────────────────────────────────── #}
                <div class="rounded-xl border p-4 mb-6 flex gap-3 items-start
                            bg-emerald-50 border-emerald-200 dark:bg-emerald-900/20 dark:border-emerald-700/40">
                    <i class="fa-solid fa-circle-check text-emerald-500 mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                    <div>
                        <p class="text-sm font-semibold text-emerald-800 dark:text-emerald-300">Link enviado com sucesso</p>
                        <p class="text-sm text-emerald-700 dark:text-emerald-400 mt-0.5 leading-relaxed">
                            Se este e-mail estiver cadastrado, você receberá as instruções em breve.
                            Verifique também a caixa de <strong>spam</strong>.
                        </p>
                    </div>
                </div>

                <div class="text-center text-sm text-slate-500 dark:text-slate-400 mb-4">
                    Não recebeu? Aguarde alguns minutos e tente novamente.
                </div>

                <a href="{{ path('app_forgot_password') }}"
                   class="btn-secondary w-full justify-center mb-3"
                   style="display:flex; text-decoration:none">
                    <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                    Tentar novamente
                </a>

                <a href="{{ path('app_login') }}"
                   class="flex items-center justify-center gap-2 text-sm text-slate-500 dark:text-slate-400
                          hover:text-primary dark:hover:text-primary-light transition-colors"
                   style="text-decoration:none">
                    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                    Voltar ao login
                </a>

            {% else %}
                {# ── Formulário ───────────────────────────────────────────── #}
                <form method="post" action="{{ path('app_forgot_password') }}" novalidate>

                    <div class="wab-field mb-6">
                        <label for="email" class="wab-label">
                            Endereço de e-mail
                        </label>
                        <div style="position:relative">
                            <i class="fa-solid fa-envelope"
                               aria-hidden="true"
                               style="position:absolute;top:50%;left:12px;transform:translateY(-50%);color:var(--bm-text-muted);font-size:14px;pointer-events:none;z-index:2"></i>
                            <input type="email"
                                   id="email"
                                   name="email"
                                   class="wab-input"
                                   required
                                   autofocus
                                   autocomplete="email"
                                   placeholder="seu@email.com"
                                   style="padding-left:38px"
                                   aria-describedby="email-hint">
                        </div>
                        <p id="email-hint" class="text-xs text-slate-400 dark:text-slate-500 mt-1.5">
                            Use o e-mail com o qual você se cadastrou.
                        </p>
                    </div>

                    <button type="submit"
                            id="btn-submit-forgot"
                            class="btn-primary w-full justify-center">
                        <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
                        Enviar link de redefinição
                    </button>

                </form>

                <div class="mt-6 text-center">
                    <a href="{{ path('app_login') }}"
                       class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400
                              hover:text-primary dark:hover:text-primary-light transition-colors"
                       style="text-decoration:none">
                        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                        Voltar ao login
                    </a>
                </div>

            {% endif %}

        </div>{# /card #}

        {# Footer #}
        <p class="text-center text-xs text-slate-400 dark:text-slate-600 mt-6">
            &copy; {{ 'now'|date('Y') }} WAB Agência Digital
        </p>

    </main>

</body>
</html>
