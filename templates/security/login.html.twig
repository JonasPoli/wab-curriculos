{% set tenant = current_tenant() %}
<!DOCTYPE html>
<html lang="pt-BR" class="">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Entrar · {{ tenant ? tenant.name : 'Administração' }}</title>
    {% if tenant and tenant.favicon %}
        <link rel="icon" type="image/x-icon" href="/uploads/tenants/favicon/{{ tenant.favicon }}">
    {% else %}
        <link rel="icon" href="/images/fav.png">
    {% endif %}

    {# Google Fonts — Inter #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">

    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          crossorigin="anonymous" referrerpolicy="no-referrer">
    {{ importmap('app') }}

    {% if tenant %}
    <style>
        :root {
            --p: {{ tenant.primaryColor|default('#0769a1') }};
            --p-light: {{ tenant.primaryColor|default('#0769a1') }};
            --s: {{ tenant.secondaryColor|default('#ffaa00') }};
        }
        html.dark {
            --p: {{ tenant.primaryColorDark|default('#3b82f6') }};
            --p-light: {{ tenant.primaryColorDark|default('#3b82f6') }};
            --s: {{ tenant.secondaryColorDark|default('#fbbf24') }};
        }
        
        .bg-primary { background-color: var(--p) !important; }
        .text-primary { color: var(--p) !important; }
        .hover\:bg-primary-light:hover { background-color: var(--p-light) !important; }
        .hover\:text-primary:hover { color: var(--p) !important; }
        html.dark .dark\:hover\:bg-primary-light:hover { background-color: var(--p-light) !important; }
        html.dark .dark\:hover\:text-primary-light:hover { color: var(--p-light) !important; }
        .bg-primary\/10 { background-color: color-mix(in srgb, var(--p) 10%, transparent) !important; }
        .bg-primary\/20 { background-color: color-mix(in srgb, var(--p) 20%, transparent) !important; }
        html.dark .dark\:bg-primary\/5 { background-color: color-mix(in srgb, var(--p) 5%, transparent) !important; }
        html.dark .dark\:bg-primary\/20 { background-color: color-mix(in srgb, var(--p) 20%, transparent) !important; }
        .shadow-primary\/20 { box-shadow: 0 10px 15px -3px color-mix(in srgb, var(--p) 20%, transparent), 0 4px 6px -4px color-mix(in srgb, var(--p) 20%, transparent) !important; }
        .focus-visible\:outline-primary:focus-visible { outline-color: var(--p) !important; }
        
        .pub-logo-dark { display: none !important; }
        html.dark .pub-logo-light { display: none !important; }
        html.dark .pub-logo-dark { display: block !important; }
    </style>
    {% endif %}

    {# Anti-FOUC dark mode #}
    <script>
        (function () {
            var theme = localStorage.theme;
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (theme === 'dark' || (!theme && prefersDark)) {
                document.documentElement.classList.add('dark', 'wa-dark');
                document.documentElement.classList.remove('wa-light');
            } else {
                document.documentElement.classList.remove('dark', 'wa-dark');
                document.documentElement.classList.add('wa-light');
            }
        })();
    </script>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-100 via-slate-50 to-white dark:from-slate-950 dark:via-slate-900 dark:to-slate-800 text-slate-800 dark:text-white antialiased flex items-center justify-center p-4">

    {# Background decorative elements #}
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/10 dark:bg-primary/5 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-indigo-500/10 dark:bg-indigo-500/5 rounded-full blur-3xl"></div>
    </div>

    <main class="relative w-full max-w-md" id="main-content">

        {# Card #}
        <div class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border border-slate-200/80 dark:border-white/10 rounded-2xl shadow-2xl shadow-slate-900/10 dark:shadow-black/40 p-8 md:p-10">

            {# Brand #}
            <div class="text-center mb-8">
                {% if tenant %}
                    {% if tenant.logo %}
                        <img src="/uploads/tenants/logo/{{ tenant.logo }}" alt="{{ tenant.name }}" class="h-12 object-contain mx-auto mb-4 pub-logo-light">
                        {% if tenant.darkLogo %}
                            <img src="/uploads/tenants/dark-logo/{{ tenant.darkLogo }}" alt="{{ tenant.name }}" class="h-12 object-contain mx-auto mb-4 pub-logo-dark">
                        {% endif %}
                    {% else %}
                        <h1 class="text-2xl font-bold tracking-tight text-primary">{{ tenant.name }}</h1>
                    {% endif %}
                    <h1 class="text-xl font-bold tracking-tight mt-2">Painel Administrativo</h1>
                {% else %}
                    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-primary/10 dark:bg-primary/20 mb-4" aria-hidden="true">
                        <i class="fa-solid fa-gauge-high text-primary dark:text-primary-light text-2xl" aria-hidden="true"></i>
                    </div>
                    <h1 class="text-2xl font-bold tracking-tight">Administração</h1>
                {% endif %}
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Acesse o painel com suas credenciais</p>
            </div>

            {# Error alert #}
            {% if error %}
                <div role="alert"
                     aria-live="assertive"
                     class="flex items-center gap-2 px-4 py-3 mb-6 rounded-lg bg-red-50 border border-red-200 text-red-700 dark:bg-red-900/20 dark:border-red-800 dark:text-red-300 text-sm">
                    <i class="fa-solid fa-circle-exclamation" aria-hidden="true" class="flex-shrink-0"></i>
                    <span class="sr-only">Erro: </span>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {# Already logged in #}
            {% if app.user %}
                <div role="status"
                     class="flex items-center gap-2 px-4 py-3 mb-6 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-700 dark:bg-emerald-900/20 dark:border-emerald-800 dark:text-emerald-300 text-sm">
                    <i class="fa-solid fa-circle-check" aria-hidden="true" class="flex-shrink-0"></i>
                    <span>
                        Logado como <strong>{{ app.user.userIdentifier }}</strong>.
                        <a href="{{ path('admin_dash') }}" class="underline font-semibold ml-1">Ir ao dashboard</a>
                        &nbsp;·&nbsp;
                        <a href="{{ path('app_logout') }}" class="underline ml-1">Sair</a>
                    </span>
                </div>
            {% endif %}

            {# Login Form #}
            <form method="post" novalidate>

                <div class="space-y-5">

                    {# Username field #}
                    <div>
                        <label for="username" class="block text-sm font-medium mb-1.5">
                            Usuário
                        </label>
                        <div style="position:relative">
                            <i class="fa-solid fa-user" aria-hidden="true" style="position:absolute;top:50%;left:11px;transform:translateY(-50%);color:#94a3b8;pointer-events:none;z-index:2;font-size:14px"></i>
                            <input type="text"
                                   id="username"
                                   name="_username"
                                   value="{{ last_username }}"
                                   class="login-input"
                                   style="padding-left:36px"
                                   autocomplete="username"
                                   required
                                   autofocus
                                   placeholder="seu.usuario">
                        </div>
                    </div>

                    {# Password field #}
                    <div>
                        <label for="password" class="block text-sm font-medium mb-1.5">
                            Senha
                        </label>
                        <div style="position:relative">
                            <span style="position:absolute;top:0;bottom:0;left:11px;display:flex;align-items:center;color:#94a3b8;pointer-events:none;z-index:1" aria-hidden="true">
                                <i class="fa-solid fa-lock" aria-hidden="true"></i>
                            </span>
                            <input type="password"
                                   id="password"
                                   name="_password"
                                   class="login-input"
                                   style="padding-left:36px;padding-right:40px"
                                   autocomplete="current-password"
                                   required
                                   placeholder="••••••••">
                            <button type="button"
                                    id="toggle-password"
                                    style="position:absolute;top:0;bottom:0;right:10px;display:flex;align-items:center;background:none;border:none;cursor:pointer;color:#94a3b8;padding:0;z-index:1"
                                    onclick="const i=document.getElementById('password');const isHidden=i.type==='password';i.type=isHidden?'text':'password';document.getElementById('toggle-icon').setAttribute('name',isHidden?'eye-slash':'eye')"
                                    aria-label="Mostrar ou ocultar senha">
                                <i class="fa-regular fa-eye"id="toggle-icon" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>

                    {# Forgot password link #}
                    <div class="text-right -mt-2">
                        <a href="{{ path('app_forgot_password') }}"
                           class="text-xs text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">
                            Esqueci a senha
                        </a>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Submit #}
                <button type="submit"
                        class="mt-6 w-full flex items-center justify-center gap-2 bg-primary hover:bg-primary-light dark:hover:bg-primary-light text-white font-semibold py-2.5 px-4 rounded-xl transition-colors shadow-lg shadow-primary/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                    <i class="fa-solid fa-arrow-right-to-bracket" aria-hidden="true"></i>
                    Entrar
                </button>

            </form>

        </div>

        {# Theme toggle at bottom #}
        <div class="flex justify-center gap-2 mt-4">
            <button type="button"
                    onclick="lightMode()"
                    class="hidden dark:inline-flex items-center gap-1.5 text-xs text-slate-400 hover:text-slate-200 transition-colors p-2 rounded-lg"
                    aria-label="Ativar modo claro">
                <i class="fa-regular fa-sun" aria-hidden="true"></i>
                Modo claro
            </button>
            <button type="button"
                    onclick="darkMode()"
                    class="dark:hidden inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-slate-700 transition-colors p-2 rounded-lg"
                    aria-label="Ativar modo escuro">
                <i class="fa-regular fa-moon" aria-hidden="true"></i>
                Modo escuro
            </button>
        </div>

    </main>

</body>
</html>
