{% extends 'pub/candidate/layout.html.twig' %}
{% block title %}Disponibilidade{% endblock %}

{% block content %}
{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

<div class="card" style="margin-bottom:1.25rem">
    <div class="card-title"><i class="fa-solid fa-calendar-check" style="color:var(--p)"></i> Horarios disponiveis</div>
    <div class="check-grid">
        {% for child in form %}
            {% if child.vars.name ends with 'Morning' or child.vars.name ends with 'Afternoon' %}
            <label class="check-item">
                {{ form_widget(child) }}
                {{ form_label(child) }}
            </label>
            {% endif %}
        {% endfor %}
    </div>
</div>

<div class="card" style="margin-bottom:1.25rem">
    <div class="card-title"><i class="fa-solid fa-briefcase" style="color:var(--p)"></i> Cargos de interesse</div>
    <div class="check-grid">
        {% for child in form.careers %}
            <label class="check-item">
                {{ form_widget(child) }}
                {{ form_label(child) }}
            </label>
        {% endfor %}
    </div>
    {% if form.careers|length == 0 %}
        <div class="empty-state">
            <i class="fa-solid fa-briefcase"></i>
            <p>Nenhum cargo cadastrado pelo RH ainda.</p>
        </div>
    {% endif %}
</div>

<button type="submit" class="btn btn-primary btn-full btn-lg">
    <i class="fa-solid fa-check"></i> Salvar disponibilidade
</button>
{{ form_end(form) }}
{% endblock %}
