{% use 'form_div_layout.html.twig' %}

{# ── Widget padrão (text, email, url, number, etc.) ─────────────────────── #}
{% block form_widget_simple %}
    {%- set attr = attr|merge({'class': (attr.class ?? '') ~ ' wab-input'}) -%}
    {{- parent() -}}
{% endblock %}

{# ── Textarea ─────────────────────────────────────────────────────────────── #}
{% block textarea_widget %}
    {%- set attr = attr|merge({'class': (attr.class ?? '') ~ ' wab-input'}) -%}
    {{- parent() -}}
{% endblock %}

{# ── Select ───────────────────────────────────────────────────────────────── #}
{% block choice_widget_collapsed %}
    {%- set attr = attr|merge({'class': (attr.class ?? '') ~ ' wab-input'}) -%}
    {{- parent() -}}
{% endblock %}

{# ── Password ─────────────────────────────────────────────────────────────── #}
{% block password_widget %}
    {%- set attr = attr|merge({'class': (attr.class ?? '') ~ ' wab-input'}) -%}
    {{- parent() -}}
{% endblock %}

{# ── Label ────────────────────────────────────────────────────────────────── #}
{% block form_label %}
    {% if label is not same as(false) %}
        {%- set label_attr = label_attr|merge({'class': (label_attr.class ?? '') ~ ' wab-label'}) -%}
        {{- parent() -}}
    {% endif %}
{% endblock %}

{# ── Erros ────────────────────────────────────────────────────────────────── #}
{% block form_errors %}
    {% if errors|length > 0 %}
        {% for error in errors %}
            <div class="wab-error" role="alert">
                <i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i>
                {{ error.message }}
            </div>
        {% endfor %}
    {% endif %}
{% endblock %}

{# ── Row container ────────────────────────────────────────────────────────── #}
{% block form_row %}
    <div class="wab-field {{ errors|length > 0 ? 'has-error' : '' }}">
        {{- form_label(form) -}}
        {{- form_widget(form) -}}
        {{- form_errors(form) -}}
    </div>
{% endblock %}

{# ── Checkbox Row ─────────────────────────────────────────────────────────── #}
{% block checkbox_row %}
    <div class="wab-field {{ errors|length > 0 ? 'has-error' : '' }}">
        <label class="flex items-center gap-2 cursor-pointer text-sm" style="font-size:13.5px; color:var(--bm-text);">
            {{- form_widget(form) -}}
            <span>{{ label|default(form.vars.label) }}</span>
        </label>
        {{- form_errors(form) -}}
    </div>
{% endblock %}

{%- block choice_widget_expanded -%}
    <div class="{{ errors|length > 0 ? 'has-error' : '' }}">
        {{- form_widget(form) -}}
        {{ label|default(form.vars.label) }}
        {{- form_errors(form) -}}
    </div>
{%- endblock choice_widget_expanded -%}


{# ── Repeated (password confirmation) ────────────────────────────────────── #}
{% block repeated_row %}
    {{- form_row(form.first) -}}
    {{- form_row(form.second) -}}
{% endblock %}
