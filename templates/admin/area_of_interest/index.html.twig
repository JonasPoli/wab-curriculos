{% extends 'admin/base.html.twig' %}

{% block title %}Áreas de Interesse{% endblock %}

{% block breadcrumbs %}
    {% set breadcrumbs = [
        { label: 'Dashboard', route: 'admin_dash' },
        { label: 'Áreas de Interesse', route: null }
    ] %}
    {{ include('admin/_partials/breadcrumbs.html.twig', { breadcrumbs: breadcrumbs }) }}
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.css">
{% endblock %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-sitemap" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Áreas de Interesse
        </h1>
        <p class="page-subtitle">Arraste para reordenar. As áreas determinam os grupos de cargos no formulário público.</p>
    </div>
    <div>
        <a href="{{ path('admin_area_of_interest_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Nova Área
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body" style="padding:0">
        {% if areas is empty %}
            <div style="padding:48px;text-align:center;opacity:.5">
                <i class="fa-solid fa-sitemap" style="font-size:2rem;margin-bottom:12px;display:block"></i>
                Nenhuma área de interesse cadastrada.
            </div>
        {% else %}
        <ul id="sortable-areas" style="list-style:none;margin:0;padding:0">
            {% for area in areas %}
            <li data-id="{{ area.id }}"
                style="display:flex;align-items:center;gap:12px;padding:14px 20px;border-bottom:1px solid var(--bm-border);cursor:grab">
                <i class="fa-solid fa-grip-vertical" style="color:var(--bm-text-muted);font-size:14px" aria-hidden="true"></i>
                <div style="flex:1">
                    <strong>{{ area.title }}</strong>
                    <span style="font-size:12px;color:var(--bm-text-muted);margin-left:8px">
                        {{ area.careers|length }} cargo{% if area.careers|length != 1 %}s{% endif %}
                    </span>
                </div>
                <div style="display:flex;gap:6px">
                    <a href="{{ path('admin_area_of_interest_edit', {id: area.id}) }}" class="btn-secondary" title="Editar">
                        <i class="fa-solid fa-pen" aria-hidden="true"></i>
                    </a>
                    <form method="post" action="{{ path('admin_area_of_interest_delete', {id: area.id}) }}"
                          onsubmit="return confirm('Excluir esta área e todos os seus cargos?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_area_' ~ area.id) }}">
                        <button type="submit" class="btn-danger" title="Excluir">
                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </li>
            {% endfor %}
        </ul>
        {% endif %}
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
    const list = document.getElementById('sortable-areas');
    if (list) {
        Sortable.create(list, {
            animation: 150,
            handle: '.fa-grip-vertical',
            onEnd: function() {
                const ids = [...list.querySelectorAll('li')].map(el => el.dataset.id);
                const body = new URLSearchParams();
                ids.forEach(id => body.append('ids[]', id));
                fetch('{{ path('admin_area_of_interest_reorder') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString()
                });
            }
        });
    }
</script>
{% endblock %}
