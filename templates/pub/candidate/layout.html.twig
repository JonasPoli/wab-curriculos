{% extends 'pub/base.html.twig' %}
{% block title %}Minha Conta{% endblock %}

{% block body %}
<div class="pub-layout">

    <aside class="pub-sidebar">
        <div class="pub-sidebar-nav">
            <div class="pub-sidebar-user">
                <div class="pub-sidebar-avatar">
                    {{ candidate.name|first|upper }}
                </div>
                <div>
                    <div class="pub-sidebar-name">{{ candidate.name }}</div>
                    <div class="pub-sidebar-email">{{ candidate.email }}</div>
                </div>
            </div>

            <a href="{{ path('pub_candidate_dashboard') }}" class="pub-nav-item {{ app.request.get('_route') == 'pub_candidate_dashboard' ? 'active' : '' }}">
                <i class="fa-solid fa-house"></i> Inicio
            </a>
            <a href="{{ path('pub_candidate_profile') }}" class="pub-nav-item {{ app.request.get('_route') starts with 'pub_candidate_profile' ? 'active' : '' }}">
                <i class="fa-solid fa-user"></i> Dados pessoais
            </a>
            <a href="{{ path('pub_candidate_experience') }}" class="pub-nav-item {{ app.request.get('_route') starts with 'pub_candidate_experience' ? 'active' : '' }}">
                <i class="fa-solid fa-briefcase"></i> Experiencias
            </a>
            <a href="{{ path('pub_candidate_academic') }}" class="pub-nav-item {{ app.request.get('_route') starts with 'pub_candidate_academic' ? 'active' : '' }}">
                <i class="fa-solid fa-graduation-cap"></i> Formacao
            </a>
            <a href="{{ path('pub_candidate_availability') }}" class="pub-nav-item {{ app.request.get('_route') starts with 'pub_candidate_availability' ? 'active' : '' }}">
                <i class="fa-solid fa-calendar-check"></i> Disponibilidade
            </a>
            <a href="{{ path('pub_candidate_access') }}" class="pub-nav-item {{ app.request.get('_route') == 'pub_candidate_access' ? 'active' : '' }}">
                <i class="fa-solid fa-lock"></i> Dados de acesso
            </a>
            <div class="pub-nav-divider"></div>
            <a href="{{ path('pub_candidate_delete_account') }}" class="pub-nav-item {{ app.request.get('_route') == 'pub_candidate_delete_account' ? 'active' : '' }}" style="color:#dc2626">
                <i class="fa-solid fa-trash"></i> Excluir conta
            </a>
        </div>
    </aside>

    <div>
        {% set progress = candidate_progress(candidate) %}
        <div class="card" style="margin-bottom:1.25rem;padding:1rem 1.5rem">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem">
                <span style="font-size:.82rem;font-weight:600;color:var(--text2)">Progresso do cadastro</span>
                <span style="font-size:.82rem;font-weight:700;color:{% if progress.percent == 100 %}#22c55e{% else %}var(--p){% endif %}">{{ progress.percent }}%</span>
            </div>
            <div class="progress-bar-wrap" style="height:6px">
                <div class="progress-bar-fill" style="width:{{ progress.percent }}%;background:{% if progress.percent == 100 %}#22c55e{% else %}var(--p){% endif %}"></div>
            </div>
            <div style="font-size:.72rem;color:var(--muted);margin-top:.4rem">
                {{ progress.doneCount }} de {{ progress.totalSteps }} etapas
                {% if progress.percent == 100 %} — Perfil completo{% endif %}
            </div>
        </div>
        {% block content %}{% endblock %}
    </div>
</div>
{% endblock %}
