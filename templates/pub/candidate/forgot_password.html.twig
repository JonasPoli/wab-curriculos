{% extends 'pub/base.html.twig' %}
{% set tenant = tenant|default(current_tenant()) %}
{% block title %}Recuperar Senha{% endblock %}

{% block body %}
<div class="pub-page-auth">
    <div style="width:100%;max-width:460px">

        <div style="text-align:center;margin-bottom:2rem">
            {% if tenant.logo %}
                <img src="{{ tenant_logo_url(tenant.logo, 'logo') }}" alt="{{ tenant.name }}" class="pub-logo-light" width="150" height="40" style="height:40px;width:auto;object-fit:contain;margin-bottom:1.5rem;margin-left:auto;margin-right:auto">
                {% if tenant.darkLogo %}
                    <img src="{{ tenant_logo_url(tenant.darkLogo, 'dark-logo') }}" alt="{{ tenant.name }}" class="pub-logo-dark" width="150" height="40" style="height:40px;width:auto;object-fit:contain;margin-bottom:1.5rem;margin-left:auto;margin-right:auto">
                {% endif %}
            {% endif %}
            <div style="width:60px;height:60px;border-radius:16px;background:color-mix(in srgb,var(--p) 12%,transparent);color:var(--p);display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin:0 auto 1.25rem">
                <i class="fa-solid fa-lock-open"></i>
            </div>
            <h1 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.5rem;font-weight:800;color:var(--text)">Recuperar senha</h1>
            <p style="font-size:.85rem;color:var(--muted);margin-top:.5rem;line-height:1.6">
                Informe seu e-mail cadastrado e enviaremos as instruções para redefinir sua senha.
            </p>
        </div>

        <div class="card">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'success' ? 'success' : 'error' }}" style="margin-bottom:1.25rem">
                        <i class="fa-solid fa-{{ type == 'success' ? 'circle-check' : 'circle-exclamation' }}"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            <form method="post">
                <div class="form-group">
                    <label class="form-label" for="email">Seu e-mail cadastrado</label>
                    <input class="form-control" type="email" id="email" name="email"
                           required autofocus placeholder="seu@email.com">
                </div>
                <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:.25rem">
                    <i class="fa-solid fa-paper-plane"></i>
                    Enviar instruções
                </button>
            </form>

            <div class="divider">ou</div>

            <a href="{{ path('pub_candidate_login') }}" class="btn btn-secondary btn-full">
                <i class="fa-solid fa-arrow-left"></i>
                Voltar ao login
            </a>
        </div>

        <p style="text-align:center;margin-top:1.5rem;font-size:.78rem;color:var(--muted)">
            Não tem conta?
            <a href="{{ path('pub_candidate_register') }}" style="color:var(--p);font-weight:600;text-decoration:none">Cadastre-se</a>
        </p>
    </div>
</div>
{% endblock %}
