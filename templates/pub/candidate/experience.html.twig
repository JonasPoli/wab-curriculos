{% extends 'pub/candidate/layout.html.twig' %}
{% block title %}Experiencias Profissionais{% endblock %}

{% block content %}

{% if candidate.workExperiences|length > 0 %}
<div class="card" style="margin-bottom:1.25rem">
    <div class="card-title"><i class="fa-solid fa-briefcase" style="color:var(--p)"></i> Suas experiencias</div>
    {% for we in candidate.workExperiences %}
    <div class="list-item">
        <div>
            <div style="font-weight:700;font-size:.9rem;color:var(--text)">{{ we.position }}</div>
            <div style="color:var(--text2);font-size:.85rem">{{ we.companyName }}</div>
            <div style="font-size:.78rem;color:var(--muted);margin-top:3px">
                {{ we.startDate ? we.startDate|date('m/Y') : '' }}
                —
                {{ we.currentJob ? 'Atual' : (we.endDate ? we.endDate|date('m/Y') : 'Atual') }}
            </div>
            {% if we.description %}
                <p style="font-size:.83rem;color:var(--muted);margin-top:.5rem;line-height:1.5">{{ we.description }}</p>
            {% endif %}
        </div>
        <form method="post" action="{{ path('pub_candidate_experience_delete', {id: we.id}) }}" onsubmit="return confirm('Remover esta experiencia?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_we_' ~ we.id) }}">
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="fa-solid fa-trash"></i>
            </button>
        </form>
    </div>
    {% endfor %}
</div>
{% endif %}

<div class="card">
    <div class="card-title"><i class="fa-solid fa-plus" style="color:var(--p)"></i> Adicionar experiencia</div>
    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
    <div class="form-row">
        <div class="form-group">
            <label class="form-label">Empresa</label>
            {{ form_widget(form.companyName, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.companyName) }}
        </div>
        <div class="form-group">
            <label class="form-label">Cargo</label>
            {{ form_widget(form.position, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.position) }}
        </div>
    </div>
    <div class="form-row">
        <div class="form-group">
            <label class="form-label">Data de inicio</label>
            {{ form_widget(form.startDate, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.startDate) }}
        </div>
        <div class="form-group">
            <label class="form-label">Data de saida</label>
            {{ form_widget(form.endDate, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.endDate) }}
        </div>
    </div>
    <div class="form-group">
        <label class="check-item" style="border:none;padding:0">
            {{ form_widget(form.currentJob) }}
            Emprego atual
        </label>
    </div>
    <div class="form-group">
        <label class="form-label">Descricao</label>
        {{ form_widget(form.description, {attr: {class: 'form-control', rows: 3, style: 'resize:vertical'}}) }}
        {{ form_errors(form.description) }}
    </div>
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Adicionar
    </button>
    {{ form_end(form) }}
</div>

{% endblock %}
