{% extends 'pub/candidate/layout.html.twig' %}
{% block title %}Dados de Acesso{% endblock %}

{% block content %}
{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
<div class="card">
    <div class="card-title"><i class="fa-solid fa-lock" style="color:var(--p)"></i> Dados de acesso</div>
    <div class="form-group">
        <label class="form-label">E-mail</label>
        {{ form_widget(form.email, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.email) }}
    </div>
    <div class="form-group">
        <label class="form-label">Nova senha</label>
        {{ form_widget(form.newPassword.first, {attr: {class: 'form-control', placeholder: 'Deixe em branco para nao alterar'}}) }}
        {{ form_errors(form.newPassword.first) }}
    </div>
    <div class="form-group">
        <label class="form-label">Confirmar nova senha</label>
        {{ form_widget(form.newPassword.second, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.newPassword.second) }}
    </div>
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-check"></i> Salvar
    </button>
</div>
{{ form_end(form) }}
{% endblock %}
