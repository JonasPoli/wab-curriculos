<!DOCTYPE html>
<html lang="pt-BR" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Redefinição de senha</title>
    <!--[if mso]>
    <noscript>
        <xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
    </noscript>
    <![endif]-->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background-color: #0d1117; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; -webkit-text-size-adjust: 100%; }
        @media (prefers-color-scheme: light) {
            body { background-color: #f1f5f9; }
            .email-wrapper { background-color: #f1f5f9 !important; }
            .email-card { background-color: #ffffff !important; border-color: #e2e8f0 !important; }
            .text-muted { color: #64748b !important; }
            .text-body { color: #1e293b !important; }
            .divider { border-color: #e2e8f0 !important; }
            .footer-text { color: #94a3b8 !important; }
        }
    </style>
</head>
<body>

{# ── Wrapper ─────────────────────────────────────────────────────────────── #}
<table class="email-wrapper" width="100%" cellpadding="0" cellspacing="0" border="0"
       style="background-color:#0d1117; padding: 40px 16px;">
    <tr>
        <td align="center">

            {# ── Card ──────────────────────────────────────────────────────── #}
            <table class="email-card" width="100%" cellpadding="0" cellspacing="0" border="0"
                   style="max-width:520px; background-color:#161b22; border:1px solid #30363d; border-radius:16px; overflow:hidden;">

                {# ── Header gradient ────────────────────────────────────────── #}
                <tr>
                    <td style="background: linear-gradient(135deg, #1d2f6f 0%, #4f8ef7 50%, #a855f7 100%); padding: 40px 40px 48px; text-align:center; position:relative;">

                        {# Logo icon #}
                        <div style="display:inline-flex; align-items:center; justify-content:center; width:60px; height:60px; background:rgba(255,255,255,.15); border-radius:16px; margin-bottom:20px; backdrop-filter:blur(10px);">
                            <img src="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6/svgs/solid/key.svg"
                                 width="28" height="28" alt=""
                                 style="filter:brightness(0) invert(1); display:block;">
                        </div>

                        <h1 style="color:#ffffff; font-size:24px; font-weight:700; margin:0 0 8px; letter-spacing:-0.3px;">
                            Redefinição de senha
                        </h1>
                        <p style="color:rgba(255,255,255,.75); font-size:14px; margin:0;">
                            Solicitação recebida
                        </p>
                    </td>
                </tr>

                {# ── Body ───────────────────────────────────────────────────── #}
                <tr>
                    <td style="padding: 36px 40px;">

                        <p class="text-body" style="color:#e6edf3; font-size:15px; line-height:1.65; margin-bottom:20px;">
                            Olá, <strong>{{ user.displayName }}</strong>!
                        </p>

                        <p class="text-muted" style="color:#8b949e; font-size:14px; line-height:1.65; margin-bottom:28px;">
                            Recebemos uma solicitação para redefinir a senha da sua conta.
                            Clique no botão abaixo para criar uma nova senha. Este link é
                            válido por <strong style="color:#e6edf3;">1 hora</strong>.
                        </p>

                        {# ── CTA Button ─────────────────────────────────────── #}
                        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:28px;">
                            <tr>
                                <td align="center">
                                    <a href="{{ resetUrl }}"
                                       target="_blank"
                                       style="display:inline-block; background: linear-gradient(135deg, #4f8ef7, #a855f7); color:#ffffff; font-size:15px; font-weight:600; text-decoration:none; padding:14px 36px; border-radius:10px; letter-spacing:0.1px; box-shadow: 0 4px 14px rgba(79,142,247,.4);">
                                        🔑 &nbsp; Redefinir minha senha
                                    </a>
                                </td>
                            </tr>
                        </table>

                        {# ── URL fallback ────────────────────────────────────── #}
                        <div style="background:#0d1117; border:1px solid #30363d; border-radius:10px; padding:16px; margin-bottom:28px; word-break:break-all;">
                            <p class="text-muted" style="color:#8b949e; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.8px; margin-bottom:8px;">
                                Link direto
                            </p>
                            <a href="{{ resetUrl }}" style="color:#4f8ef7; font-size:12px; text-decoration:none; word-break:break-all;">
                                {{ resetUrl }}
                            </a>
                        </div>

                        {# ── Info box ───────────────────────────────────────── #}
                        <div style="background:rgba(245,158,11,.08); border:1px solid rgba(245,158,11,.25); border-radius:10px; padding:16px; margin-bottom:28px;">
                            <p style="color:#fbbf24; font-size:13px; font-weight:600; margin-bottom:6px;">
                                ⚠️ &nbsp; Atenção
                            </p>
                            <p style="color:#d97706; font-size:13px; line-height:1.6; margin:0;">
                                Se você <strong>não solicitou</strong> a redefinição de senha, ignore este e-mail.
                                Sua senha permanece a mesma e nenhuma alteração foi feita.
                            </p>
                        </div>

                        {# Expiry info #}
                        <p class="text-muted" style="color:#8b949e; font-size:13px; line-height:1.6; margin:0;">
                            Este link expira em
                            <strong style="color:#e6edf3;">{{ expiresAt|date('d/m/Y \\à\\s H:i') }}</strong>.
                            Após expirar, você precisará solicitar um novo link.
                        </p>

                    </td>
                </tr>

                {# ── Divider ─────────────────────────────────────────────────── #}
                <tr>
                    <td style="padding: 0 40px;">
                        <hr class="divider" style="border:none; border-top:1px solid #30363d; margin:0;">
                    </td>
                </tr>

                {# ── Footer ──────────────────────────────────────────────────── #}
                <tr>
                    <td style="padding: 24px 40px; text-align:center;">
                        <p class="footer-text" style="color:#6e7681; font-size:12px; line-height:1.6; margin:0;">
                            Você recebeu este e-mail porque uma solicitação de redefinição
                            de senha foi feita para a conta associada a
                            <strong style="color:#8b949e;">{{ user.email }}</strong>.<br>
                            &copy; {{ 'now'|date('Y') }} WAB Agência Digital
                        </p>
                    </td>
                </tr>

            </table>
            {# /card #}

        </td>
    </tr>
</table>

</body>
</html>
