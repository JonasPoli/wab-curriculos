{% extends 'admin/base.html.twig' %}

{% block title %}Usuários Admin{% endblock %}

{% block breadcrumbs %}
    {% set breadcrumbs = [
        { label: 'Dashboard', route: 'admin_dash' },
        { label: 'Usuários Admin', route: null }
    ] %}
    {{ include('admin/_partials/breadcrumbs.html.twig', { breadcrumbs: breadcrumbs }) }}
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <style>
        /* ── Modal overlay ─────────────────────────────────────────────────── */
        .wab-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, .55);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            opacity: 0;
            visibility: hidden;
            transition: opacity .22s ease, visibility .22s ease;
        }
        .wab-modal-backdrop.open {
            opacity: 1;
            visibility: visible;
        }

        /* ── Modal box ─────────────────────────────────────────────────────── */
        .wab-modal {
            background: var(--bm-surface, #fff);
            border-radius: 18px;
            box-shadow: 0 32px 80px rgba(0,0,0,.25), 0 8px 24px rgba(0,0,0,.12);
            width: 100%;
            max-width: 440px;
            overflow: hidden;
            transform: scale(.94) translateY(12px);
            transition: transform .25s cubic-bezier(.34,1.56,.64,1);
        }
        .wab-modal-backdrop.open .wab-modal {
            transform: scale(1) translateY(0);
        }

        /* ── Modal header ──────────────────────────────────────────────────── */
        .wab-modal-header {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            padding: 1.75rem 1.75rem 1.25rem;
            position: relative;
            overflow: hidden;
        }
        .wab-modal-header::before {
            content: '';
            position: absolute;
            top: -40px; right: -40px;
            width: 120px; height: 120px;
            border-radius: 50%;
            background: rgba(255,255,255,.08);
        }
        .wab-modal-header::after {
            content: '';
            position: absolute;
            bottom: -30px; left: 20px;
            width: 80px; height: 80px;
            border-radius: 50%;
            background: rgba(255,255,255,.05);
        }
        .wab-modal-icon {
            width: 52px; height: 52px;
            border-radius: 14px;
            background: rgba(255,255,255,.18);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            color: #fff;
            margin-bottom: 1rem;
            position: relative; z-index: 1;
        }
        .wab-modal-title {
            font-size: 1.15rem;
            font-weight: 800;
            color: #fff;
            font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
            margin-bottom: .25rem;
            position: relative; z-index: 1;
        }
        .wab-modal-subtitle {
            font-size: .8rem;
            color: rgba(255,255,255,.7);
            font-weight: 500;
            position: relative; z-index: 1;
        }

        /* ── Modal body ────────────────────────────────────────────────────── */
        .wab-modal-body {
            padding: 1.5rem 1.75rem;
        }
        .wab-modal-user-card {
            background: var(--bm-bg, #f8fafc);
            border: 1.5px solid var(--bm-border, #e2e8f0);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 1.25rem;
        }
        .wab-modal-avatar {
            width: 46px; height: 46px;
            border-radius: 12px;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800;
            font-size: 1.1rem;
            flex-shrink: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        .wab-modal-user-name {
            font-weight: 700;
            font-size: .9rem;
            color: var(--bm-text, #0f172a);
        }
        .wab-modal-user-meta {
            font-size: .78rem;
            color: var(--bm-text-muted, #64748b);
            margin-top: 2px;
        }
        .wab-modal-tenant-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(79,70,229,.12);
            color: #4f46e5;
            border-radius: 999px;
            padding: 3px 10px;
            font-size: .72rem;
            font-weight: 700;
        }
        .wab-modal-warning {
            background: #fffbeb;
            border: 1.5px solid #fde68a;
            border-radius: 10px;
            padding: .85rem 1rem;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: .8rem;
            color: #92400e;
            line-height: 1.5;
        }
        .wab-modal-warning i { color: #d97706; margin-top: 1px; flex-shrink: 0; }

        /* ── Modal footer ──────────────────────────────────────────────────── */
        .wab-modal-footer {
            padding: 1rem 1.75rem 1.5rem;
            display: flex;
            gap: .75rem;
            justify-content: flex-end;
        }
        .wab-btn-cancel {
            padding: 10px 20px;
            border-radius: 9px;
            border: 1.5px solid var(--bm-border, #e2e8f0);
            background: transparent;
            color: var(--bm-text-muted, #64748b);
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: all .18s;
        }
        .wab-btn-cancel:hover { background: var(--bm-bg, #f8fafc); color: var(--bm-text, #0f172a); }
        .wab-btn-confirm {
            padding: 10px 22px;
            border-radius: 9px;
            border: none;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: #fff;
            font-size: .875rem;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all .18s;
            box-shadow: 0 4px 14px rgba(79,70,229,.4);
        }
        .wab-btn-confirm:hover {
            opacity: .88;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(79,70,229,.5);
        }

        /* ── Delete modal ──────────────────────────────────────────────────── */
        .wab-modal-header.danger {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
        }
        .wab-modal-warning.danger {
            background: #fef2f2;
            border-color: #fecaca;
            color: #7f1d1d;
        }
        .wab-modal-warning.danger i { color: #dc2626; }
        .wab-btn-confirm.danger {
            background: linear-gradient(135deg, #dc2626, #b91c1c);
            box-shadow: 0 4px 14px rgba(220,38,38,.4);
        }
        .wab-btn-confirm.danger:hover { box-shadow: 0 6px 20px rgba(220,38,38,.5); }
    </style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-user-shield" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Usuários Admin
        </h1>
        <p class="page-subtitle">Gerencie os usuários administrativos de cada tenant.</p>
    </div>
    <div>
        <a href="{{ path('admin_user_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Novo Usuário
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table id="users-table" class="display nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nome</th>
                    <th>Username</th>
                    <th>E-mail</th>
                    <th>Perfil</th>
                    <th>Tenant</th>
                    <th>Criado em</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:8px">
                            <div style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--bm-accent),#7c3aed);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;flex-shrink:0">
                                {{ (user.name ?? user.username)|first|upper }}
                            </div>
                            <strong style="font-size:.875rem">{{ user.name ?? '—' }}</strong>
                        </div>
                    </td>
                    <td><code>{{ user.username }}</code></td>
                    <td>{{ user.email }}</td>
                    <td>
                        {% if user.isSuperAdmin %}
                            <span class="badge badge-red">Super Admin</span>
                        {% elseif user.workGroup %}
                            <span class="badge badge-blue">{{ user.workGroup.label() }}</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if user.tenant %}
                            <span class="badge badge-green">{{ user.tenant.name }}</span>
                        {% else %}
                            <span class="badge" style="background:rgba(168,85,247,.15);color:#a855f7">Global</span>
                        {% endif %}
                    </td>
                    <td>{{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}</td>
                    <td>
                        <div style="display:flex;gap:6px;align-items:center">
                            {% if user.tenant and not user.isSuperAdmin and user != app.user %}
                                <button type="button"
                                        class="btn-secondary btn-impersonate"
                                        style="font-size:.78rem;padding:5px 10px;color:var(--bm-accent);border-color:var(--bm-accent)"
                                        data-name="{{ (user.name ?? user.username)|e('html_attr') }}"
                                        data-username="{{ user.username|e('html_attr') }}"
                                        data-tenant="{{ user.tenant.name|e('html_attr') }}"
                                        data-url="{{ (path('admin_dash') ~ '?_switch_user=' ~ user.username|url_encode)|e('html_attr') }}">
                                    <i class="fa-solid fa-user-secret" aria-hidden="true"></i>
                                    Impersonar
                                </button>
                            {% endif %}
                            <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn-secondary" title="Editar" style="padding:5px 10px">
                                <i class="fa-solid fa-pen" aria-hidden="true"></i>
                            </a>
                            {% if user != app.user %}
                            <button type="button"
                                    class="btn-danger btn-delete"
                                    style="padding:5px 10px"
                                    data-name="{{ (user.name ?? user.username)|e('html_attr') }}"
                                    data-form-id="delete-form-{{ user.id }}">
                                <i class="fa-solid fa-trash" aria-hidden="true"></i>
                            </button>
                            <form id="delete-form-{{ user.id }}" method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" style="display:none">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                            </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="8" style="text-align:center;padding:40px;opacity:.5">Nenhum usuário cadastrado.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ══ MODAL IMPERSONAR ════════════════════════════════════════════════════════ #}
<div class="wab-modal-backdrop" id="modal-impersonate" role="dialog" aria-modal="true" aria-labelledby="modal-impersonate-title">
    <div class="wab-modal">
        <div class="wab-modal-header">
            <div class="wab-modal-icon"><i class="fa-solid fa-user-secret"></i></div>
            <div class="wab-modal-title" id="modal-impersonate-title">Confirmar Impersonação</div>
            <div class="wab-modal-subtitle">Você vai assumir a identidade deste usuário</div>
        </div>
        <div class="wab-modal-body">
            <div class="wab-modal-user-card">
                <div class="wab-modal-avatar" id="imp-avatar">?</div>
                <div>
                    <div class="wab-modal-user-name" id="imp-name">—</div>
                    <div class="wab-modal-user-meta">
                        <code id="imp-username" style="font-size:.78rem"></code>
                    </div>
                    <div style="margin-top:6px">
                        <span class="wab-modal-tenant-badge">
                            <i class="fa-solid fa-building" style="font-size:.65rem"></i>
                            <span id="imp-tenant">—</span>
                        </span>
                    </div>
                </div>
            </div>
            <div class="wab-modal-warning">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>Após confirmar, você estará operando <strong>como este usuário</strong>. Todas as ações serão realizadas em nome dele. Use o botão <em>"Sair da impersonação"</em> para retornar à sua conta.</span>
            </div>
        </div>
        <div class="wab-modal-footer">
            <button type="button" class="wab-btn-cancel" onclick="closeModal('modal-impersonate')">
                <i class="fa-solid fa-xmark"></i>
                Cancelar
            </button>
            <a href="#" id="imp-confirm-btn" class="wab-btn-confirm">
                <i class="fa-solid fa-user-secret"></i>
                Sim, impersonar
            </a>
        </div>
    </div>
</div>

{# ══ MODAL EXCLUIR ═══════════════════════════════════════════════════════════ #}
<div class="wab-modal-backdrop" id="modal-delete" role="dialog" aria-modal="true" aria-labelledby="modal-delete-title">
    <div class="wab-modal">
        <div class="wab-modal-header danger">
            <div class="wab-modal-icon"><i class="fa-solid fa-trash"></i></div>
            <div class="wab-modal-title" id="modal-delete-title">Excluir Usuário</div>
            <div class="wab-modal-subtitle">Esta ação não pode ser desfeita</div>
        </div>
        <div class="wab-modal-body">
            <div class="wab-modal-user-card">
                <div class="wab-modal-avatar" style="background:linear-gradient(135deg,#dc2626,#b91c1c)" id="del-avatar">?</div>
                <div>
                    <div class="wab-modal-user-name" id="del-name">—</div>
                </div>
            </div>
            <div class="wab-modal-warning danger">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>O usuário será <strong>permanentemente removido</strong> do sistema. Todos os dados associados serão perdidos.</span>
            </div>
        </div>
        <div class="wab-modal-footer">
            <button type="button" class="wab-btn-cancel" onclick="closeModal('modal-delete')">
                <i class="fa-solid fa-xmark"></i>
                Cancelar
            </button>
            <button type="button" class="wab-btn-confirm danger" id="del-confirm-btn">
                <i class="fa-solid fa-trash"></i>
                Excluir definitivamente
            </button>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
<script>
    new DataTable('#users-table', {
        language: { url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json' },
        pageLength: 25,
        columnDefs: [{ orderable: false, targets: [7] }]
    });

    function openModal(id) {
        const el = document.getElementById(id);
        el.classList.add('open');
        document.body.style.overflow = 'hidden';
        el.addEventListener('click', function(e) {
            if (e.target === el) closeModal(id);
        }, { once: true });
    }

    function closeModal(id) {
        const el = document.getElementById(id);
        el.classList.remove('open');
        document.body.style.overflow = '';
    }

    function openImpersonateModal({ name, username, tenant, url }) {
        document.getElementById('imp-avatar').textContent   = name.charAt(0).toUpperCase();
        document.getElementById('imp-name').textContent     = name;
        document.getElementById('imp-username').textContent = username;
        document.getElementById('imp-tenant').textContent   = tenant;
        document.getElementById('imp-confirm-btn').href     = url;
        openModal('modal-impersonate');
    }

    function openDeleteModal({ name, formId }) {
        document.getElementById('del-avatar').textContent = name.charAt(0).toUpperCase();
        document.getElementById('del-name').textContent   = name;
        document.getElementById('del-confirm-btn').onclick = function() {
            document.getElementById(formId).submit();
        };
        openModal('modal-delete');
    }

    // Event delegation via data-* attributes (no inline onclick escaping issues)
    document.addEventListener('click', function(e) {
        const impBtn = e.target.closest('.btn-impersonate');
        if (impBtn) {
            openImpersonateModal({
                name:     impBtn.dataset.name,
                username: impBtn.dataset.username,
                tenant:   impBtn.dataset.tenant,
                url:      impBtn.dataset.url
            });
            return;
        }
        const delBtn = e.target.closest('.btn-delete');
        if (delBtn) {
            openDeleteModal({
                name:   delBtn.dataset.name,
                formId: delBtn.dataset.formId
            });
        }
    });

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            closeModal('modal-impersonate');
            closeModal('modal-delete');
        }
    });
</script>
{% endblock %}