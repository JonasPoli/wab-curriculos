// ── Checa renderização ────────────────────────────────────────────────────────
function checkRendered() {
    document.querySelectorAll('.icon-card').forEach(card => {
        const name = card.dataset.name;
        const isBrands = card.querySelector('i.fa-brands') !== null;

        let visible = true;
        if (!isBrands && currentVariant === 'regular') {
            visible = FA6_REGULAR_FREE.has(name);
        }

        card.dataset.norender = visible ? '' : '1';
        if (!visible) {
            card.style.display = 'none';
        } else if (!card.classList.contains('search-hidden')) {
            card.style.display = '';
        }
    });

    document.querySelectorAll('.cat-section').forEach(sec => {
        const visible = sec.querySelectorAll('.icon-card:not([style*="display: none"]):not([style*="display:none"])').length;
        const cnt = sec.querySelector('.cat-count');
        if (cnt) cnt.textContent = visible;
        sec.style.display = visible === 0 ? 'none' : '';
    });

    updateCount();
}

let currentVariant = 'solid';
const VARIANT_CLASSES = ['fa-solid', 'fa-regular', 'fa-light', 'fa-duotone', 'fa-thin'];

function buildLibrary() {
    const container = document.getElementById('icon-library');
    container.innerHTML = '';

    for (const [cat, names] of Object.entries(ICON_CATEGORIES)) {
        const isBrands = cat.includes('brands');
        const prefix   = isBrands ? 'fa-brands' : `fa-${currentVariant}`;

        const section = document.createElement('div');
        section.className = 'cat-section';

        section.innerHTML = `
            <div class="cat-title">
                ${cat}
                <span class="cat-count">…</span>
            </div>
            <div class="icon-grid"></div>
        `;
        container.appendChild(section);
        const grid = section.querySelector('.icon-grid');

        [...new Set(names)].forEach(name => {
            const card = document.createElement('button');
            card.type = 'button';
            card.className = 'icon-card';
            card.dataset.name = name;
            card.title = name;
            card.setAttribute('aria-label', `Copiar ícone ${name}`);
            card.innerHTML = `<i class="${prefix} fa-${name}" aria-hidden="true"></i>
                <span class="icon-name">${name}</span>`;
            card.addEventListener('click', () => copyIcon(name, isBrands));
            grid.appendChild(card);
        });
    }

    // Conta inicial sem ocultar (Solid mostra tudo)
    requestAnimationFrame(() => requestAnimationFrame(() => {
        document.querySelectorAll('.cat-section').forEach(sec => {
            const cnt = sec.querySelector('.cat-count');
            if (cnt) cnt.textContent = sec.querySelectorAll('.icon-card').length;
        });
        updateCount();
    }));
}

function setVariant(variant, btn) {
    currentVariant = variant;
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');

    // Mostra todos e troca a classe de variante
    document.querySelectorAll('#icon-library .icon-card').forEach(card => {
        delete card.dataset.norender;
        if (!card.classList.contains('search-hidden')) card.style.display = '';

        const el = card.querySelector('i');
        if (el && !el.classList.contains('fa-brands')) {
            VARIANT_CLASSES.forEach(v => el.classList.remove(v));
            el.classList.add(`fa-${variant}`);
        }
    });

    // Filtra usando a lista fixa (instantâneo, sem timing)
    checkRendered();
}

function filterIcons() {
    const q = document.getElementById('icon-search').value.toLowerCase().trim();
    let shown = 0;
    document.querySelectorAll('.icon-card').forEach(card => {
        const matchSearch = !q || card.dataset.name.includes(q);
        const matchVariant = card.dataset.norender !== '1';
        card.classList.toggle('search-hidden', !matchSearch);
        card.style.display = (matchSearch && matchVariant) ? '' : 'none';
        if (matchSearch && matchVariant) shown++;
    });
    document.querySelectorAll('.cat-section').forEach(sec => {
        const visible = sec.querySelectorAll('.icon-card:not([style*="display: none"]):not([style*="display:none"])').length;
        sec.style.display = visible === 0 ? 'none' : '';
        const cnt = sec.querySelector('.cat-count');
        if (cnt) cnt.textContent = visible;
    });
    updateCount(shown);
}

function updateCount(shown) {
    const total = document.querySelectorAll('.icon-card:not([style*="display: none"]):not([style*="display:none"])').length;
    const el = document.getElementById('icon-count');
    if (shown !== undefined && shown !== total) {
        el.textContent = `${shown} de ${total} ícones`;
    } else {
        el.textContent = `${total} ícones — ${currentVariant === 'regular' ? 'FA6 Free Regular (~157 ícones)' : 'FA6 Free Solid'}`;
    }
}

function copyIcon(name, isBrands) {
    const prefix = isBrands ? 'fa-brands' : `fa-${currentVariant}`;
    const code = `<i class="${prefix} fa-${name}" aria-hidden="true"></i>`;
    navigator.clipboard.writeText(code).then(() => {
        const t = document.getElementById('copy-toast');
        t.textContent = `✓ ${name}`;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 1800);
    }).catch(() => prompt('Copie:', code));
}

document.addEventListener('DOMContentLoaded', buildLibrary);
</script>
