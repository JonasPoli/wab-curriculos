{#
    Shared form partial for User create/edit.
    Usage: {{ include('admin/user/_form.html.twig', { button_label: 'Salvar' }) }}
#}
{{ form_start(form, { attr: { novalidate: 'novalidate', class: 'space-y-5' } }) }}

    {# ── Name ──────────────────────────────────────────────────────────── #}
    <div>
        {{ form_label(form.name, null, { label_attr: { class: 'block text-sm font-medium mb-1.5' } }) }}
        {{ form_widget(form.name, { attr: { class: 'login-input' } }) }}
        {{ form_errors(form.name) }}
    </div>

    {# ── Username ───────────────────────────────────────────────────────── #}
    <div>
        {{ form_label(form.username, null, { label_attr: { class: 'block text-sm font-medium mb-1.5' } }) }}
        {{ form_widget(form.username, { attr: { class: 'login-input' } }) }}
        {{ form_errors(form.username) }}
    </div>

    {# ── E-mail ─────────────────────────────────────────────────────────── #}
    <div>
        {{ form_label(form.email, null, { label_attr: { class: 'block text-sm font-medium mb-1.5' } }) }}
        {{ form_widget(form.email, { attr: { class: 'login-input' } }) }}
        {{ form_errors(form.email) }}
    </div>

    {# ── Roles ──────────────────────────────────────────────────────────── #}
    <fieldset>
        <legend class="block text-sm font-medium mb-2">
            {{ form_label(form.roles) }}
        </legend>
        <div class="flex flex-wrap gap-4 pl-1">
            {% for choice in form.roles %}
                <label class="flex items-center gap-2 cursor-pointer text-sm">
                    {{ form_widget(choice) }}
                    <span>{{ choice.vars.label }}</span>
                </label>
            {% endfor %}
        </div>
        {{ form_errors(form.roles) }}
    </fieldset>

    {# ── Password ───────────────────────────────────────────────────────── #}
    <div class="border-t border-slate-100 dark:border-slate-800 pt-5">
        <p class="text-sm font-medium mb-3 text-slate-700 dark:text-slate-200">Senha</p>

        {# First password field #}
        <div class="mb-4">
            {{ form_label(form.plainPassword.first, null, { label_attr: { class: 'block text-sm font-medium mb-1.5' } }) }}
            {{ form_widget(form.plainPassword.first, { attr: { class: 'login-input' } }) }}
            {{ form_errors(form.plainPassword.first) }}
        </div>

        {# Second password field (confirmation) #}
        <div>
            {{ form_label(form.plainPassword.second, null, { label_attr: { class: 'block text-sm font-medium mb-1.5' } }) }}
            {{ form_widget(form.plainPassword.second, { attr: { class: 'login-input' } }) }}
            {{ form_errors(form.plainPassword.second) }}
            {% if not form.vars.data.id %}
                <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">Mínimo de 8 caracteres.</p>
            {% else %}
                <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">
                    Deixe em branco para manter a senha atual.
                </p>
            {% endif %}
        </div>
    </div>

    {# ── Global form errors ─────────────────────────────────────────────── #}
    {{ form_errors(form) }}

    {# ── Submit Button ──────────────────────────────────────────────────── #}
    <div class="flex pt-2">
        <button type="submit"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary hover:bg-primary-dark text-white text-sm font-semibold transition-colors shadow-sm shadow-primary/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
            <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
            {{ button_label|default('Salvar') }}
        </button>
    </div>

{{ form_end(form) }}